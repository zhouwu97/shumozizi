{
  "schema_name": "competition_profile",
  "schema_version": "2.0",
  "profile_id": "mcm",
  "profile_version": "1.0.0",
  "display_name": "COMAP MCM/ICM",
  "rules_status": "official-sources-reviewed",
  "rules_sources": [
    {
      "url": "https://www.contest.comap.com/undergraduate/contests/mcm/instructions.php",
      "authority": "COMAP",
      "purpose": "页数、单 PDF、摘要首页、匿名与 AI 使用规则"
    }
  ],
  "page_limit": 25,
  "a4_required": true,
  "page_margin_cm": 2.5,
  "max_file_size_bytes": null,
  "anonymous_required": true,
  "required_submission_files": ["paper/final.pdf"],
  "judge_visible_roles": [
    "problem_source",
    "problem_attachments_manifest",
    "competition_rules",
    "final_pdf",
    "submission_manifest"
  ],
  "summary_first_page": true,
  "mechanical_qa": {
    "duplicate_caption_pattern": "(?i)(?:figure|fig\\.|table)\\s*([0-9]+)[：:.\\s]",
    "anonymous_forbidden_patterns": ["(?i)author\\s*:", "(?i)university\\s*:", "(?i)school\\s*:", "(?i)student\\s+id\\s*:"] ,
    "require_figure_qa_receipts": true
  },
  "format_audit": {
    "fonts_embedded_required": true,
    "keywords_required": false,
    "references_required": true,
    "citation_links_required": false,
    "min_image_dpi": 150
  },
  "warnings": ["若使用 AI，仍须按当届官方规则核对披露与附加报告要求"]
}
