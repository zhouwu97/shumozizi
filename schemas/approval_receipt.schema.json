{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://github.com/zhouwu97/shumozizi/schemas/approval_receipt.schema.json",
  "type": "object", "additionalProperties": false, "required": ["schema_name", "schema_version", "run_id", "approval_kind", "approval_request_sha256", "bindings", "raw_user_response", "normalized_selection", "delegated_items", "decision", "approved_by", "approval_source", "approved_at"],
  "properties": {"schema_name": {"const": "approval_receipt"}, "schema_version": {"const": "2.0"}, "run_id": {"type": "string"}, "approval_kind": {"enum": ["route", "config_change"]}, "approval_request_sha256": {"$ref": "#/$defs/sha"}, "bindings": {"type": "object", "additionalProperties": {"$ref": "#/$defs/sha"}}, "raw_user_response": {"type": "string", "minLength": 1}, "normalized_selection": {"type": "string", "minLength": 1}, "delegated_items": {"type": "array", "items": {"type": "string"}}, "decision": {"const": "approved"}, "approved_by": {"type": "string", "minLength": 1}, "approval_source": {"const": "codex-desktop-user-message"}, "approved_at": {"type": "string", "format": "date-time"}}, "$defs": {"sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
