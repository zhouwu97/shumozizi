{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atomic_pattern_review_report.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_name", "schema_version", "pattern_id", "pattern_sha256", "review_session_id", "reviewer_identity", "verdict", "findings", "reviewed_at"],
  "properties": {
    "schema_name": {"const": "atomic_pattern_review_report"},
    "schema_version": {"const": "1.0"},
    "pattern_id": {"type": "string", "minLength": 1},
    "pattern_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "review_session_id": {"type": "string", "minLength": 1},
    "reviewer_identity": {"type": "string", "minLength": 1},
    "verdict": {"enum": ["verified", "revision_required", "rejected"]},
    "findings": {"type": "array", "items": {"type": "object"}},
    "reviewed_at": {"type": "string", "format": "date-time"}
  }
}
