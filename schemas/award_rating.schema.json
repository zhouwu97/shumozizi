{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/award_rating.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["grade", "confidence", "basis", "downgrade_reasons", "expert_estimate"],
  "properties": {
    "grade": {"enum": ["A", "B", "C", "D", "E"]},
    "confidence": {"enum": ["low", "medium", "high"]},
    "basis": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "downgrade_reasons": {"type": "array", "items": {"type": "string"}},
    "expert_estimate": {"const": true}
  }
}
