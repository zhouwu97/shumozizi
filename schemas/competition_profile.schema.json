{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/competition_profile.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_name", "schema_version", "profile_id", "profile_version", "display_name", "rules_status", "rules_sources", "page_limit", "anonymous_required", "required_submission_files", "summary_first_page", "mechanical_qa", "warnings"],
  "properties": {
    "schema_name": {"const": "competition_profile"},
    "schema_version": {"const": "2.0"},
    "profile_id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "profile_version": {"type": "string"},
    "display_name": {"type": "string", "minLength": 1},
    "rules_status": {"enum": ["generic", "official-sources-reviewed", "official-confirmation-required"]},
    "rules_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["url", "authority", "purpose"],
        "properties": {
          "url": {"type": "string", "format": "uri"},
          "authority": {"type": "string"},
          "purpose": {"type": "string"}
        }
      }
    },
    "page_limit": {"type": ["integer", "null"], "minimum": 1},
    "a4_required": {"type": "boolean"},
    "page_margin_cm": {"type": "number", "minimum": 0},
    "max_file_size_bytes": {"type": ["integer", "null"], "minimum": 1},
    "anonymous_required": {"type": "boolean"},
    "required_submission_files": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "judge_visible_roles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "problem_source",
          "problem_attachments_manifest",
          "competition_rules",
          "final_pdf",
          "submission_manifest",
          "allowed_submission_attachments",
          "submission_code",
          "commitment_statement",
          "ai_use_statement"
        ]
      }
    },
    "summary_first_page": {"type": "boolean"},
    "mechanical_qa": {
      "type": "object",
      "additionalProperties": false,
      "required": ["duplicate_caption_pattern", "anonymous_forbidden_patterns", "require_figure_qa_receipts"],
      "properties": {
        "duplicate_caption_pattern": {"type": "string"},
        "anonymous_forbidden_patterns": {"type": "array", "items": {"type": "string"}},
        "require_figure_qa_receipts": {"type": "boolean"}
      }
    },
    "format_audit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fonts_embedded_required", "keywords_required", "references_required", "citation_links_required", "min_image_dpi"],
      "properties": {
        "fonts_embedded_required": {"type": "boolean"},
        "keywords_required": {"type": "boolean"},
        "references_required": {"type": "boolean"},
        "citation_links_required": {"type": "boolean"},
        "min_image_dpi": {"type": "number", "minimum": 1}
      }
    },
    "warnings": {"type": "array", "items": {"type": "string"}}
  }
}
