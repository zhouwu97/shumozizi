{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://github.com/zhouwu97/shumozizi/schemas/evidence_map.schema.json",
  "type": "object", "additionalProperties": false, "required": ["schema_name", "schema_version", "run_id", "claims"],
  "properties": {"schema_name": {"const": "evidence_map"}, "schema_version": {"const": "2.0"}, "run_id": {"type": "string"}, "claims": {"type": "array", "items": {"type": "object", "required": ["claim_id", "inputs", "display"], "properties": {"claim_id": {"type": "string"}, "inputs": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["name", "result_id", "metric_spec_id"], "properties": {"name": {"type": "string"}, "result_id": {"type": "string"}, "metric_spec_id": {"type": "string"}}}}, "expression": {"type": ["object", "null"]}, "display": {"type": "object", "required": ["decimals", "unit"], "properties": {"decimals": {"type": "integer", "minimum": 0, "maximum": 10}, "unit": {"type": "string"}, "scale": {"type": "number"}}}, "core": {"type": "boolean"}}}}}
}
