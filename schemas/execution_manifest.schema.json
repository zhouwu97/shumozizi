{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://github.com/zhouwu97/shumozizi/schemas/execution_manifest.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_name", "schema_version", "execution_id", "program", "args", "cwd", "timeout_seconds", "input_files", "expected_outputs", "random_seed"],
  "properties": {"schema_name": {"const": "execution_manifest"}, "schema_version": {"const": "2.0"}, "execution_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"}, "question_id": {"type": "string", "minLength": 1}, "experiment_family": {"enum": ["baseline", "primary", "robustness", "ablation"]}, "planned_budget_usage": {"type": "object", "additionalProperties": false, "required": ["model_fits", "optimization_evaluations", "invalid_tuning_attempts"], "properties": {"model_fits": {"type": "integer", "minimum": 0}, "optimization_evaluations": {"type": "integer", "minimum": 0}, "invalid_tuning_attempts": {"type": "integer", "minimum": 0}}}, "program": {"const": "python"}, "args": {"type": "array", "minItems": 1, "maxItems": 128, "items": {"type": "string", "maxLength": 4096}}, "cwd": {"type": "string", "minLength": 1}, "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 3600}, "input_files": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "expected_outputs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "random_seed": {"type": ["integer", "null"]}}
}
