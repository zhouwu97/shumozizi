{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/execution_manifest.schema.json",
  "title": "MathModelAgent Experiment Execution Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "execution_id",
    "program",
    "args",
    "cwd",
    "timeout_seconds",
    "input_files",
    "expected_outputs",
    "random_seed"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "execution_id": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
    "program": { "const": "python" },
    "args": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": { "type": "string", "maxLength": 4096 }
    },
    "cwd": { "type": "string", "minLength": 1 },
    "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 3600 },
    "input_files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "expected_outputs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "random_seed": { "type": ["integer", "null"] }
  }
}
