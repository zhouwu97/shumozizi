{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://github.com/zhouwu97/shumozizi/schemas/execution_record.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_name", "schema_version", "execution_id", "manifest_path", "manifest_sha256", "started_at", "finished_at", "duration_seconds", "exit_code", "timed_out", "program", "executable", "args", "cwd", "timeout_seconds", "random_seed", "stdout_path", "stderr_path", "input_files", "expected_outputs", "output_files", "runner_version"],
  "properties": {"schema_name": {"const": "execution_record"}, "schema_version": {"const": "2.0"}, "execution_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"}, "manifest_path": {"type": "string"}, "manifest_sha256": {"$ref": "#/$defs/sha"}, "started_at": {"type": "string", "format": "date-time"}, "finished_at": {"type": "string", "format": "date-time"}, "duration_seconds": {"type": "number", "minimum": 0}, "exit_code": {"type": "integer"}, "timed_out": {"type": "boolean"}, "program": {"const": "python"}, "executable": {"type": "string", "minLength": 1}, "args": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "cwd": {"type": "string", "minLength": 1}, "timeout_seconds": {"type": "integer", "minimum": 1}, "random_seed": {"type": ["integer", "null"]}, "stdout_path": {"type": "string"}, "stderr_path": {"type": "string"}, "input_files": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/file"}}, "expected_outputs": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "output_files": {"type": "array", "items": {"$ref": "#/$defs/file"}}, "runner_version": {"const": "2.0.0"}},
  "$defs": {"sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "file": {"type": "object", "additionalProperties": false, "required": ["path", "sha256", "size_bytes"], "properties": {"path": {"type": "string"}, "sha256": {"$ref": "#/$defs/sha"}, "size_bytes": {"type": "integer", "minimum": 0}}}}
}
