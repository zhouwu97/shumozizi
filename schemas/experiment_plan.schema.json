{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/experiment_plan.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name",
    "schema_version",
    "run_id",
    "experiment_id",
    "question_id",
    "experiment_role",
    "hypothesis",
    "prediction_ids",
    "baseline_result_ids",
    "metrics",
    "comparison_rule",
    "randomness_plan",
    "stop_rule",
    "expected_outputs",
    "claim_ids"
  ],
  "properties": {
    "schema_name": {"const": "experiment_plan"},
    "schema_version": {"const": "2.0"},
    "run_id": {"type": "string", "minLength": 1},
    "experiment_id": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
    "question_id": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
    "experiment_role": {
      "enum": ["baseline", "primary", "robustness", "ablation", "robustness_or_ablation"]
    },
    "hypothesis": {"type": "string", "minLength": 2},
    "prediction_ids": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"}
    },
    "baseline_result_ids": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"}
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "comparison_rule": {"$ref": "#/$defs/comparison_rule"},
    "randomness_plan": {"$ref": "#/$defs/randomness_plan"},
    "stop_rule": {"type": "string", "minLength": 2},
    "expected_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "claim_ids": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"}
    },
    "route_lock_sha256": {"$ref": "#/$defs/sha"}
  },
  "$defs": {
    "sha": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "comparison_predicate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metric", "relation", "threshold", "unit", "aggregation"],
      "properties": {
        "prediction_id": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
        "metric": {"type": "string", "minLength": 1},
        "relation": {
          "enum": [
            "relative_increase",
            "relative_decrease",
            "relative_decrease_at_most",
            "relative_increase_at_most",
            "absolute_increase",
            "absolute_decrease",
            "absolute_decrease_at_most",
            "absolute_increase_at_most",
            "stable"
          ]
        },
        "threshold": {"type": "number"},
        "unit": {"type": "string", "minLength": 1},
        "aggregation": {"type": "string", "minLength": 1}
      }
    },
    "comparison_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "predicates",
        "supported_if",
        "partially_supported_if",
        "rejected_if",
        "otherwise"
      ],
      "properties": {
        "predicates": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/comparison_predicate"}
        },
        "supported_if": {"const": "all_required_predictions_pass"},
        "partially_supported_if": {"const": "at_least_one_required_prediction_passes"},
        "rejected_if": {"const": "any_falsification_condition_passes"},
        "otherwise": {"const": "inconclusive"}
      }
    },
    "randomness_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["applicable"],
      "properties": {
        "applicable": {"type": "boolean"},
        "seeds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "integer"}
        },
        "reason": {"type": "string", "minLength": 10}
      },
      "allOf": [
        {
          "if": {"properties": {"applicable": {"const": true}}},
          "then": {"required": ["seeds"], "not": {"required": ["reason"]}}
        },
        {
          "if": {"properties": {"applicable": {"const": false}}},
          "then": {"required": ["reason"], "not": {"required": ["seeds"]}}
        }
      ]
    }
  }
}
