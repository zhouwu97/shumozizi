{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/figure_render_receipt.schema.json",
  "title": "Capability-First v3 Figure Render Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_name", "schema_version", "run_id", "figure_id", "engine", "rendering_mode", "command", "exit_code", "timed_out", "script", "inputs", "outputs", "stdout", "stderr", "started_at", "finished_at"],
  "properties": {
    "schema_name": {"const": "figure_render"},
    "schema_version": {"const": "1.0"},
    "run_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
    "figure_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
    "engine": {"enum": ["python", "matlab", "octave"]},
    "rendering_mode": {"enum": ["2d", "3d", "orthographic", "diagram"]},
    "command": {"type": "array", "minItems": 2, "items": {"type": "string", "minLength": 1}},
    "exit_code": {"const": 0},
    "timed_out": {"const": false},
    "script": {"$ref": "#/$defs/file"},
    "inputs": {"type": "array", "items": {"$ref": "#/$defs/file"}},
    "outputs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/file"}},
    "stdout": {"$ref": "#/$defs/file"},
    "stderr": {"$ref": "#/$defs/file"},
    "started_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "size_bytes"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha"},
        "size_bytes": {"type": "integer", "minimum": 0}
      }
    }
  }
}
