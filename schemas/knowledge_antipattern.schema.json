{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "knowledge_antipattern.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_name", "schema_version", "pattern_id", "antipattern_type", "title", "applicable_when", "not_applicable_when", "required_evidence", "detection_signals", "harms", "corrections", "source_paper_ids", "origin", "review_status", "authoring_session_id"],
  "properties": {
    "schema_name": {"const": "knowledge_antipattern"},
    "schema_version": {"const": "1.0"},
    "pattern_id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "antipattern_type": {"enum": ["data_leakage", "pseudo_innovation", "model_stacking", "non_discriminating_robustness", "figure_conclusion_disconnect", "good_fit_unidentifiable", "complexity_without_decision_value"]},
    "title": {"type": "string", "minLength": 1},
    "applicable_when": {"$ref": "#/$defs/strings"},
    "not_applicable_when": {"$ref": "#/$defs/strings"},
    "required_evidence": {"$ref": "#/$defs/strings"},
    "detection_signals": {"$ref": "#/$defs/strings"},
    "harms": {"$ref": "#/$defs/strings"},
    "corrections": {"$ref": "#/$defs/strings"},
    "source_paper_ids": {"$ref": "#/$defs/strings"},
    "origin": {"enum": ["paper_card", "postmortem", "manual_research"]},
    "review_status": {"enum": ["provisional", "revision_required"]},
    "authoring_session_id": {"type": "string", "minLength": 1}
  },
  "$defs": {"strings": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}}
}
