{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "knowledge_review_thread_claim.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_name", "schema_version", "thread_id", "paper_id", "request_id", "request_path", "request_sha256", "session_path", "session_sha256", "claimed_at"],
  "properties": {
    "schema_name": {"const": "knowledge_review_thread_claim"},
    "schema_version": {"const": "1.0"},
    "thread_id": {"type": "string", "minLength": 1},
    "paper_id": {"type": "string", "minLength": 1},
    "request_id": {"type": "string", "minLength": 1},
    "request_path": {"type": "string", "pattern": "^knowledge/reviews/requests/"},
    "request_sha256": {"$ref": "#/$defs/sha256"},
    "session_path": {"type": "string", "pattern": "^knowledge/reviews/requests/"},
    "session_sha256": {"$ref": "#/$defs/sha256"},
    "claimed_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
