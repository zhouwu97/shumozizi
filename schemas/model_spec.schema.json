{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/model_spec.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_name", "schema_version", "run_id", "route_lock_sha256", "questions"],
  "properties": {
    "schema_name": {"const": "model_spec"},
    "schema_version": {"const": "2.0"},
    "run_id": {"type": "string"},
    "route_lock_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "questions": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["question_id", "model_family", "target_role", "feature_roles", "variables", "assumptions", "objective", "constraints", "algorithm", "validation_plan"], "properties": {"question_id": {"type": "string"}, "model_family": {"enum": ["statistical", "optimization", "prediction", "simulation", "classification"]}, "target_role": {"type": "string", "minLength": 1}, "feature_roles": {"type": "array", "items": {"type": "string"}}, "variables": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["name", "role", "unit"], "properties": {"name": {"type": "string"}, "role": {"type": "string"}, "unit": {"type": "string"}}}}, "assumptions": {"type": "array", "items": {"type": "string"}}, "objective": {"type": "string"}, "constraints": {"type": "array", "items": {"type": "string"}}, "algorithm": {"type": "string"}, "validation_plan": {"type": "array", "minItems": 1, "items": {"type": "string"}}}}}
  }
}
