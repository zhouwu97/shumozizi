{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/paper_build_receipt.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_name", "schema_version", "run_id", "plan_path", "plan_sha256", "state_revision", "final_pdf_path", "final_pdf_sha256", "generated_at"],
  "properties": {
    "schema_name": {"const": "paper_build_receipt"},
    "schema_version": {"const": "2.0"},
    "run_id": {"type": "string", "minLength": 1},
    "plan_path": {"type": "string", "minLength": 1},
    "plan_sha256": {"$ref": "#/$defs/sha"},
    "state_revision": {"type": "integer", "minimum": 0},
    "final_pdf_path": {"type": "string", "minLength": 1},
    "final_pdf_sha256": {"$ref": "#/$defs/sha"},
    "generated_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {"sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
