{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "paper_card_evidence_map.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name",
    "schema_version",
    "paper_id",
    "card_sha256",
    "source_id",
    "source_asset_sha256",
    "claims"
  ],
  "properties": {
    "schema_name": {"const": "paper_card_evidence_map"},
    "schema_version": {"const": "1.0"},
    "paper_id": {"type": "string", "minLength": 1},
    "card_sha256": {"$ref": "#/$defs/sha256"},
    "source_id": {"type": "string", "minLength": 1},
    "source_asset_sha256": {"$ref": "#/$defs/sha256"},
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_id",
          "card_claim",
          "source_page",
          "section",
          "location",
          "source_excerpt_sha256",
          "review_confidence"
        ],
        "properties": {
          "claim_id": {"type": "string", "minLength": 1},
          "card_claim": {"type": "string", "minLength": 1},
          "source_page": {"type": "string", "minLength": 1},
          "section": {"type": "string", "minLength": 1},
          "location": {"type": "string", "minLength": 1},
          "source_excerpt_sha256": {"$ref": "#/$defs/sha256"},
          "review_confidence": {"enum": ["low", "medium", "high"]}
        }
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
