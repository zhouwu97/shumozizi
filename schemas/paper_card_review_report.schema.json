{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "paper_card_review_report.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name",
    "schema_version",
    "paper_id",
    "card_sha256",
    "evidence_map_sha256",
    "source_asset_sha256",
    "review_session_id",
    "reviewer_identity",
    "reviewer_attestation",
    "verdict",
    "findings",
    "reviewed_at"
  ],
  "properties": {
    "schema_name": {"const": "paper_card_review_report"},
    "schema_version": {"const": "1.0"},
    "paper_id": {"type": "string", "minLength": 1},
    "card_sha256": {"$ref": "#/$defs/sha256"},
    "evidence_map_sha256": {"$ref": "#/$defs/sha256"},
    "source_asset_sha256": {"$ref": "#/$defs/sha256"},
    "review_session_id": {"type": "string", "minLength": 1},
    "reviewer_identity": {"type": "string", "minLength": 1},
    "reviewer_attestation": {"type": "string", "minLength": 1},
    "verdict": {"enum": ["verified", "revision_required", "rejected"]},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["finding_id", "severity", "description", "status"],
        "properties": {
          "finding_id": {"type": "string", "minLength": 1},
          "severity": {"enum": ["P0", "P1", "P2", "P3"]},
          "description": {"type": "string", "minLength": 1},
          "status": {"enum": ["open", "resolved", "advisory"]}
        }
      }
    },
    "reviewed_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
