{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "paper_card_v2.schema.json",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "paper_id",
    "card_version",
    "source_id",
    "source_asset_sha256",
    "canonical_problem_id",
    "problem_asset_sha256",
    "paper_asset_sha256",
    "problem_type",
    "data_structure",
    "task_types",
    "model_family",
    "validation_methods",
    "assumption_pattern",
    "argument_pattern",
    "failure_modes",
    "transferable_patterns",
    "non_transferable_context",
    "evidence_locations",
    "review_status",
    "authoring_session_id"
  ],
  "properties": {
    "paper_id": {"type": "string", "minLength": 1},
    "card_version": {"const": "2.0"},
    "source_id": {"type": "string", "minLength": 1},
    "source_asset_sha256": {"$ref": "#/$defs/sha256"},
    "canonical_problem_id": {"type": "string", "minLength": 1},
    "problem_asset_sha256": {"$ref": "#/$defs/sha256"},
    "paper_asset_sha256": {"$ref": "#/$defs/sha256"},
    "problem_type": {"type": "string", "minLength": 1},
    "data_structure": {"type": "string", "minLength": 1},
    "task_types": {"$ref": "#/$defs/string_array"},
    "model_family": {"$ref": "#/$defs/string_array"},
    "validation_methods": {"$ref": "#/$defs/string_array"},
    "assumption_pattern": {"type": "string", "minLength": 1},
    "argument_pattern": {"type": "string", "minLength": 1},
    "failure_modes": {"$ref": "#/$defs/string_array"},
    "transferable_patterns": {"$ref": "#/$defs/string_array"},
    "non_transferable_context": {"type": "string", "minLength": 1},
    "evidence_locations": {"$ref": "#/$defs/string_array"},
    "review_status": {"enum": ["provisional", "revision_required"]},
    "authoring_session_id": {"type": "string", "minLength": 1}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "string_array": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
