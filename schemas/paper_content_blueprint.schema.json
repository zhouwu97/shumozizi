{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/paper_content_blueprint.schema.json",
  "title": "Paper Content Sufficiency Blueprint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name",
    "schema_version",
    "run_id",
    "state_revision",
    "execution_mode",
    "required_questions",
    "data_processing_applicable",
    "sections",
    "generated_at"
  ],
  "properties": {
    "schema_name": {"const": "paper_content_blueprint"},
    "schema_version": {"const": "2.0"},
    "run_id": {"type": "string", "minLength": 1},
    "state_revision": {"type": "integer", "minimum": 0},
    "execution_mode": {"const": "production"},
    "required_questions": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "data_processing_applicable": {"type": "boolean"},
    "source_code_appendix": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/source_file"}
    },
    "matlab_proof_figures": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/matlab_proof_figure"}
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/section"}
    },
    "generated_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "source_file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_path", "appendix_path", "sha256", "source_text"],
      "properties": {
        "source_path": {"type": "string", "pattern": "^code/.+\\.(py|m)$"},
        "appendix_path": {"type": "string", "pattern": "^paper/source_appendix/.+\\.(py|m)$"},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "source_text": {"type": "string", "minLength": 1}
      }
    },
    "matlab_proof_figure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_kind",
        "figure_id",
        "question_id",
        "scientific_question",
        "receipt_path",
        "receipt_sha256",
        "script_path",
        "script_sha256",
        "output_paths",
        "output_sha256s"
      ],
      "properties": {
        "proof_kind": {"enum": ["geometry", "optimization"]},
        "figure_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
        "question_id": {"type": "string", "minLength": 1},
        "scientific_question": {"type": "string", "minLength": 16},
        "receipt_path": {"type": "string", "pattern": "^figures/receipts/.+\\.json$"},
        "receipt_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "script_path": {"type": "string", "pattern": "^code/matlab/.+\\.m$"},
        "script_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "output_paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^figures/.+\\.png$"}
        },
        "output_sha256s": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        }
      }
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "section_id",
        "kind",
        "required",
        "draft_allowed",
        "evidence_result_ids",
        "required_elements"
      ],
      "properties": {
        "section_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
        "kind": {"enum": ["global", "question", "appendix"]},
        "question_id": {"type": "string", "minLength": 1},
        "required": {"type": "boolean"},
        "draft_allowed": {"type": "boolean"},
        "evidence_result_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"}
        },
        "required_elements": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "argument_contract": {
          "$ref": "#/$defs/argument_contract"
        },
        "blocked_reason": {"type": "string", "minLength": 2}
      }
    },
    "argument_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chosen_objective",
        "model_choice_rationale",
        "core_proof_obligations",
        "production_result_refs",
        "comparison_route",
        "evidence_interpretation",
        "unproved_boundary",
        "direct_answer"
      ],
      "properties": {
        "chosen_objective": {"type": "string", "minLength": 10},
        "model_choice_rationale": {"type": "string", "minLength": 10},
        "core_proof_obligations": {
          "type": "array", "minItems": 1,
          "items": {"type": "string", "minLength": 3}
        },
        "production_result_refs": {
          "type": "array", "minItems": 0, "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"}
        },
        "comparison_route": {"type": "string", "minLength": 10},
        "evidence_interpretation": {"type": "string", "minLength": 10},
        "unproved_boundary": {"type": "string", "minLength": 10},
        "direct_answer": {"type": "string", "minLength": 10}
      }
    }
  }
}
