{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/paper_content_blueprint.schema.json",
  "title": "Paper Content Sufficiency Blueprint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name",
    "schema_version",
    "run_id",
    "state_revision",
    "execution_mode",
    "required_questions",
    "data_processing_applicable",
    "sections",
    "generated_at"
  ],
  "properties": {
    "schema_name": {"const": "paper_content_blueprint"},
    "schema_version": {"const": "2.0"},
    "run_id": {"type": "string", "minLength": 1},
    "state_revision": {"type": "integer", "minimum": 0},
    "execution_mode": {"const": "production"},
    "required_questions": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "data_processing_applicable": {"type": "boolean"},
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/section"}
    },
    "generated_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "section_id",
        "kind",
        "required",
        "draft_allowed",
        "evidence_result_ids",
        "required_elements"
      ],
      "properties": {
        "section_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
        "kind": {"enum": ["global", "question", "appendix"]},
        "question_id": {"type": "string", "minLength": 1},
        "required": {"type": "boolean"},
        "draft_allowed": {"type": "boolean"},
        "evidence_result_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"}
        },
        "required_elements": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "blocked_reason": {"type": "string", "minLength": 2}
      }
    }
  }
}
