{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/paper_plan.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_name", "schema_version", "run_id", "bindings", "referenced_result_ids", "final_pdf_path"],
  "properties": {
    "schema_name": {"const": "paper_plan"},
    "schema_version": {"const": "2.0"},
    "run_id": {"type": "string", "minLength": 1},
    "referenced_result_ids": {
      "type": "array",
      "minItems": 0,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mathmodel_paper", "writing_skill", "typst_author", "competition_template", "model_spec", "result_registry", "claim_gate", "section_files", "figures_used"],
      "properties": {
        "mathmodel_paper": {"$ref": "#/$defs/file"},
        "writing_skill": {"$ref": "#/$defs/file"},
        "typst_author": {"$ref": "#/$defs/file"},
        "competition_template": {"$ref": "#/$defs/file"},
        "model_spec": {"$ref": "#/$defs/file"},
        "result_registry": {"$ref": "#/$defs/file"},
        "claim_gate": {"$ref": "#/$defs/file"},
        "section_files": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/file"}},
        "figures_used": {"type": "array", "items": {"$ref": "#/$defs/file"}}
      }
    },
    "final_pdf_path": {"type": "string", "minLength": 1}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha"}}
    }
  }
}
