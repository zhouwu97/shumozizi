{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/paper_reference_receipt.schema.json",
  "title": "Offline Paper Writing Reference Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name",
    "schema_version",
    "run_id",
    "state_revision",
    "execution_mode",
    "frozen_phase",
    "production_result_ids",
    "paper_index",
    "reference_role",
    "prohibited_uses",
    "cards",
    "registered_at"
  ],
  "properties": {
    "schema_name": {"const": "paper_reference_receipt"},
    "schema_version": {"const": "2.0"},
    "run_id": {"type": "string", "minLength": 1},
    "state_revision": {"type": "integer", "minimum": 0},
    "execution_mode": {"const": "production"},
    "frozen_phase": {"enum": ["paper", "paper_review", "verify", "final_review", "complete"]},
    "production_result_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"}
    },
    "paper_index": {"$ref": "#/$defs/file_binding"},
    "reference_role": {"const": "offline_writing_reference"},
    "prohibited_uses": {
      "const": [
        "rendering",
        "citation",
        "evidence",
        "claim_evidence",
        "result_reference",
        "fact_source"
      ]
    },
    "cards": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/card"}
    },
    "registered_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "file_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha"}
      }
    },
    "card": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "paper_id",
        "card_path",
        "card_sha256",
        "source_sha256",
        "allowed_uses"
      ],
      "properties": {
        "paper_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
        "card_path": {"type": "string", "minLength": 1},
        "card_sha256": {"$ref": "#/$defs/sha"},
        "source_sha256": {"$ref": "#/$defs/sha"},
        "allowed_uses": {
          "const": [
            "section_organization",
            "model_explanation",
            "validation_narrative",
            "figure_contract"
          ]
        }
      }
    }
  }
}
