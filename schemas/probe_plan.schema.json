{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/probe_plan.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name", "schema_version", "run_id", "request_id", "finding_id",
    "source_report_sha256", "source_adjudication_sha256",
    "question", "hypothesis", "probe_type", "allowed_files", "allowed_commands",
    "budget", "success_condition", "failure_condition", "inconclusive_condition",
    "expected_outputs", "generated_at"
  ],
  "properties": {
    "schema_name": {"const": "probe_plan"},
    "schema_version": {"const": "2.0"},
    "run_id": {"type": "string", "minLength": 1},
    "request_id": {"type": "string", "minLength": 1},
    "finding_id": {"type": "string", "minLength": 1},
    "source_report_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "source_adjudication_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "question": {"type": "string", "minLength": 1},
    "hypothesis": {"type": "string", "minLength": 1},
    "probe_type": {"enum": ["exact_oracle", "synthetic_recovery", "small_instance_enumeration", "independent_reimplementation", "permutation_test", "sensitivity_probe", "constraint_counterexample", "unit_consistency_probe"]},
    "allowed_files": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "allowed_commands": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "budget": {
      "type": "object", "additionalProperties": false,
      "required": ["max_minutes", "max_commands", "max_output_bytes"],
      "properties": {
        "max_minutes": {"type": "integer", "minimum": 1},
        "max_commands": {"type": "integer", "minimum": 1},
        "max_output_bytes": {"type": "integer", "minimum": 1}
      }
    },
    "success_condition": {"type": "string", "minLength": 1},
    "failure_condition": {"type": "string", "minLength": 1},
    "inconclusive_condition": {"type": "string", "minLength": 1},
    "expected_outputs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "generated_at": {"type": "string", "format": "date-time"}
  }
}
