{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/problem_manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name",
    "schema_version",
    "run_id",
    "run_config_lock_sha256",
    "problem_source",
    "questions",
    "frozen_at"
  ],
  "properties": {
    "schema_name": {"const": "problem_manifest"},
    "schema_version": {"const": "2.0"},
    "run_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
    "run_config_lock_sha256": {"$ref": "#/$defs/sha"},
    "problem_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha"}
      }
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/question"}
    },
    "frozen_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "required_output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["output_id", "description"],
      "properties": {
        "output_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
        "description": {"type": "string", "minLength": 2},
        "unit": {"type": ["string", "null"]}
      }
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "question_id",
        "title",
        "required",
        "required_outputs",
        "depends_on",
        "source_refs"
      ],
      "properties": {
        "question_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
        "title": {"type": "string", "minLength": 2},
        "required": {"type": "boolean"},
        "required_outputs": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/required_output"}
        },
        "depends_on": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"}
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
