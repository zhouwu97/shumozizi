{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://github.com/zhouwu97/shumozizi/schemas/qa_report.schema.json",
  "type": "object", "additionalProperties": false, "required": ["schema_name", "schema_version", "run_id", "status", "final_pdf_path", "final_pdf_sha256", "run_config_lock_sha256", "evidence_report_sha256", "source_manifest_path", "source_manifest_sha256", "format_audit_path", "format_audit_sha256", "checks", "hard_failures", "warnings", "generated_at"],
  "properties": {"schema_name": {"const": "qa_report"}, "schema_version": {"const": "2.0"}, "run_id": {"type": "string"}, "status": {"enum": ["pass", "blocked"]}, "final_pdf_path": {"type": "string"}, "final_pdf_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "run_config_lock_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "evidence_report_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "source_manifest_path": {"const": "source/SOURCE_MANIFEST.json"}, "source_manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "format_audit_path": {"const": "review/FORMAT_AUDIT.json"}, "format_audit_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "checks": {"type": "array", "items": {"type": "object", "required": ["check_id", "passed", "hard", "details"], "properties": {"check_id": {"type": "string"}, "passed": {"type": "boolean"}, "hard": {"type": "boolean"}, "details": {"type": "string"}}}}, "hard_failures": {"type": "array", "items": {"type": "string"}}, "warnings": {"type": "array", "items": {"type": "string"}}, "generated_at": {"type": "string", "format": "date-time"}}
}
