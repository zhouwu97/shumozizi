{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/question_acceptance.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_name", "schema_version", "run_id", "question_id", "status", "checks", "accepted_result_ids", "chapter_paths", "direct_answer", "claim_status", "generated_at"],
  "properties": {
    "schema_name": {"const": "question_acceptance"},
    "schema_version": {"const": "2.0"},
    "run_id": {"type": "string", "minLength": 1},
    "question_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
    "status": {"enum": ["accepted", "rejected"]},
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["question_requirements", "model_output", "output_mapping", "hard_constraints", "baseline", "accepted_result", "uncertainty", "direct_answer", "upstream_dependencies", "claim_status"],
      "properties": {
        "question_requirements": {"$ref": "#/$defs/check"},
        "model_output": {"$ref": "#/$defs/check"},
        "output_mapping": {"$ref": "#/$defs/check"},
        "hard_constraints": {"$ref": "#/$defs/check"},
        "baseline": {"$ref": "#/$defs/check"},
        "accepted_result": {"$ref": "#/$defs/check"},
        "uncertainty": {"$ref": "#/$defs/check"},
        "direct_answer": {"$ref": "#/$defs/check"},
        "upstream_dependencies": {"$ref": "#/$defs/check"},
        "claim_status": {"$ref": "#/$defs/check"}
      }
    },
    "accepted_result_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "chapter_paths": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^paper/sections/.+"}},
    "direct_answer": {"type": "string", "minLength": 1},
    "claim_status": {"enum": ["supported", "partially_supported", "rejected", "inconclusive", "none"]},
    "generated_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "evidence"],
      "properties": {"passed": {"type": "boolean"}, "evidence": {"type": "string", "minLength": 1}}
    }
  }
}
