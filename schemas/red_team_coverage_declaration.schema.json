{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/red_team_coverage_declaration.schema.json",
  "title": "红队覆盖声明",
  "description": "审核 AI 在自由报告完成后输出的轻量覆盖声明，用于防止关键词扫描退化。协调程序仅核对 risk_id 是否均有结论并标注报告位置。",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_name", "schema_version", "run_id", "review_file", "covered_risks"],
  "properties": {
    "schema_name": {"const": "red_team_coverage_declaration"},
    "schema_version": {"const": "1.0"},
    "run_id": {"type": "string", "minLength": 1},
    "review_file": {"type": "string", "minLength": 1, "description": "自由审查报告在 review/ 下的相对路径，如 SCIENTIFIC_RED_TEAM.md"},
    "covered_risks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["risk_id", "conclusion", "evidence_location"],
        "properties": {
          "risk_id": {
            "type": "string",
            "minLength": 1,
            "description": "当前路由要求覆盖的高风险方向标识，如 optimization-multiseed、geometry-continuous"
          },
          "conclusion": {
            "enum": ["sufficient", "insufficient", "not_applicable", "requires_independent_verification"],
            "description": "审核 AI 对该风险的最终判断；insufficient 或 requires_independent_verification 会触发专项追问"
          },
          "evidence_location": {
            "type": "string",
            "minLength": 1,
            "description": "自由报告中论证此结论的位置，如 SCIENTIFIC_RED_TEAM.md#搜索稳定性"
          },
          "follow_up_required": {
            "type": "boolean",
            "default": false,
            "description": "审核 AI 判断是否需要针对该风险的专项追问"
          }
        }
      }
    },
    "required_follow_ups": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["risk_id", "question"],
        "properties": {
          "risk_id": {"type": "string", "minLength": 1},
          "question": {"type": "string", "minLength": 1, "description": "针对该风险应追问的具体问题"}
        }
      }
    },
    "generated_at": {"type": "string", "format": "date-time"}
  }
}
