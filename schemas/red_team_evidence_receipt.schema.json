{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/red_team_evidence_receipt.schema.json",
  "title": "Capability-First v3 Red Team Evidence Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_name", "schema_version", "run_id", "evidence_id", "kind", "command", "exit_code", "timed_out", "script", "inputs", "outputs", "stdout", "stderr", "started_at", "finished_at"],
  "properties": {
    "schema_name": {"const": "red_team_evidence"},
    "schema_version": {"enum": ["1.0", "1.1", "1.2"]},
    "run_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
    "evidence_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
    "kind": {"enum": ["independent-recompute", "counterexample", "small-enumeration", "alternative-formula", "search-challenge", "property-test", "action-activation-challenge", "geometry-continuous-validation"]},
    "engine": {"enum": ["python", "matlab", "octave"]},
    "packet": {"$ref": "#/$defs/packet"},
    "command": {"type": "array", "minItems": 2, "items": {"type": "string", "minLength": 1}},
    "exit_code": {"const": 0},
    "timed_out": {"const": false},
    "script": {"$ref": "#/$defs/file"},
    "inputs": {"type": "array", "items": {"$ref": "#/$defs/file"}},
    "outputs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/file"}},
    "semantic_output": {"$ref": "#/$defs/file"},
    "stdout": {"$ref": "#/$defs/file"},
    "stderr": {"$ref": "#/$defs/file"},
    "started_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": "string", "format": "date-time"}
  },
  "allOf": [
    {
      "if": {"properties": {"schema_version": {"const": "1.1"}}},
      "then": {"required": ["engine", "packet"]}
    },
    {
      "if": {"properties": {"schema_version": {"const": "1.2"}}},
      "then": {"required": ["engine", "packet", "semantic_output"]}
    }
  ],
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "size_bytes"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha"},
        "size_bytes": {"type": "integer", "minimum": 0}
      }
    },
    "packet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest_file", "manifest_sha256", "packet_tree_sha256"],
      "properties": {
        "manifest_file": {"type": "string", "minLength": 1},
        "manifest_sha256": {"$ref": "#/$defs/sha"},
        "packet_tree_sha256": {"$ref": "#/$defs/sha"}
      }
    }
  }
}
