{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/red_team_semantic_output.schema.json",
  "title": "Red Team Semantic Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "evidence"],
  "properties": {
    "kind": {"enum": ["independent-recompute", "counterexample", "small-enumeration", "alternative-formula", "search-challenge", "property-test", "action-activation-challenge", "fixed-action-utilization", "geometry-continuous-validation"]},
    "evidence": {"type": "object"}
  },
  "allOf": [
    {
      "if": {"properties": {"kind": {"enum": ["independent-recompute", "alternative-formula"]}}},
      "then": {"properties": {"evidence": {"$ref": "#/$defs/recompute"}}}
    },
    {
      "if": {"properties": {"kind": {"const": "counterexample"}}},
      "then": {"properties": {"evidence": {"$ref": "#/$defs/counterexample"}}}
    },
    {
      "if": {"properties": {"kind": {"const": "small-enumeration"}}},
      "then": {"properties": {"evidence": {"$ref": "#/$defs/enumeration"}}}
    },
    {
      "if": {"properties": {"kind": {"const": "search-challenge"}}},
      "then": {"properties": {"evidence": {"$ref": "#/$defs/search"}}}
    },
    {
      "if": {"properties": {"kind": {"const": "property-test"}}},
      "then": {"properties": {"evidence": {"$ref": "#/$defs/property"}}}
    },
    {
      "if": {"properties": {"kind": {"const": "action-activation-challenge"}}},
      "then": {"properties": {"evidence": {"$ref": "#/$defs/actionActivation"}}}
    },
    {
      "if": {"properties": {"kind": {"const": "fixed-action-utilization"}}},
      "then": {"properties": {"evidence": {"$ref": "#/$defs/fixedActionUtilization"}}}
    },
    {
      "if": {"properties": {"kind": {"const": "geometry-continuous-validation"}}},
      "then": {"properties": {"evidence": {"$ref": "#/$defs/geometryContinuous"}}}
    }
  ],
  "$defs": {
    "recompute": {
      "type": "object",
      "required": ["claim_id", "method", "cases", "production_value", "independent_value", "absolute_difference", "verdict"],
      "properties": {
        "claim_id": {"type": "string", "minLength": 1},
        "question_id": {"type": "string", "minLength": 1},
        "method": {"type": "string", "minLength": 3},
        "cases": {"type": "integer", "minimum": 1},
        "production_value": {"type": "number"},
        "independent_value": {"type": "number"},
        "absolute_difference": {"type": "number", "minimum": 0},
        "verdict": {"enum": ["consistent", "inconsistent"]}
      }
    },
    "counterexample": {
      "type": "object",
      "required": ["claim_id", "case", "expected", "production_observed", "violated_invariant", "verdict"],
      "properties": {
        "claim_id": {"type": "string", "minLength": 1},
        "case": {"type": "object", "minProperties": 1},
        "expected": {"type": "boolean"},
        "production_observed": {"type": "boolean"},
        "violated_invariant": {"type": "string", "minLength": 3},
        "verdict": {"const": "counterexample_found"}
      }
    },
    "enumeration": {
      "type": "object",
      "required": ["claim_id", "method", "cases", "mismatches", "verdict"],
      "properties": {
        "claim_id": {"type": "string", "minLength": 1},
        "method": {"type": "string", "minLength": 3},
        "cases": {"type": "integer", "minimum": 1},
        "mismatches": {"type": "integer", "minimum": 0},
        "verdict": {"enum": ["consistent", "inconsistent"]}
      }
    },
    "search": {
      "type": "object",
      "required": ["incumbent_exact", "challenge_best_exact", "evaluation_budget", "independent_candidates", "feasible_candidates", "verdict"],
      "properties": {
        "incumbent_exact": {"type": "number"},
        "challenge_best_exact": {"type": "number"},
        "evaluation_budget": {"type": "integer", "minimum": 1},
        "independent_candidates": {"type": "integer", "minimum": 1},
        "feasible_candidates": {"type": "integer", "minimum": 0},
        "verdict": {"enum": ["incumbent_competitive", "incumbent_not_competitive", "inconclusive"]}
      }
    },
    "property": {
      "type": "object",
      "required": ["claim_id", "property", "cases", "failures", "verdict"],
      "properties": {
        "claim_id": {"type": "string", "minLength": 1},
        "property": {"type": "string", "minLength": 3},
        "cases": {"type": "integer", "minimum": 1},
        "failures": {"type": "integer", "minimum": 0},
        "verdict": {"enum": ["pass", "fail"]}
      }
    },
    "geometryContinuous": {
      "type": "object",
      "additionalProperties": false,
      "required": ["question_id", "continuous_quantity", "sampled_approximation", "verification_method", "discretization_error_bound", "critical_cases", "verdict"],
      "properties": {
        "question_id": {"type": "string", "minLength": 1},
        "continuous_quantity": {"type": "string", "minLength": 2},
        "sampled_approximation": {"type": ["string", "null"], "minLength": 2},
        "verification_method": {"enum": ["continuous_1d_optimization", "interval_verification", "root_isolation", "explicit_discretization_error"]},
        "discretization_error_bound": {"type": ["number", "null"], "minimum": 0},
        "critical_cases": {
          "type": "object",
          "additionalProperties": false,
          "required": ["left_endpoint", "right_endpoint", "tangent", "degenerate", "outside_segment"],
          "properties": {
            "left_endpoint": {"type": "boolean"},
            "right_endpoint": {"type": "boolean"},
            "tangent": {"type": "boolean"},
            "degenerate": {"type": "boolean"},
            "outside_segment": {"type": "boolean"}
          }
        },
        "verdict": {"enum": ["pass", "fail"]}
      }
    },
    "actionActivation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "question_id",
        "allowed_action_count",
        "incumbent_active_count",
        "unused_actions_exist",
        "discrete_activation_variables",
        "variable_bounds_sha256",
        "exact_scorer_sha256",
        "objective_direction",
        "improvement_tolerance",
        "evaluation_budget",
        "seeds",
        "first_feasible_evaluation",
        "feasible_rate",
        "proxy_exact_max_error",
        "best_so_far",
        "coverage_method",
        "coverage_details",
        "rounds",
        "consecutive_no_improvement_rounds",
        "incumbent_exact",
        "challenge_best_exact",
        "verdict"
      ],
      "properties": {
        "question_id": {"type": "string", "minLength": 1},
        "allowed_action_count": {"type": "integer", "minimum": 1},
        "incumbent_active_count": {"type": "integer", "minimum": 0},
        "unused_actions_exist": {"type": "boolean"},
        "discrete_activation_variables": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "variable_bounds_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "exact_scorer_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "objective_direction": {"enum": ["maximize", "minimize"]},
        "improvement_tolerance": {"type": "number", "minimum": 0},
        "evaluation_budget": {"type": "integer", "minimum": 1},
        "seeds": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {"type": "integer"}
        },
        "first_feasible_evaluation": {
          "oneOf": [{"type": "null"}, {"type": "integer", "minimum": 1}]
        },
        "feasible_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "proxy_exact_max_error": {"type": "number", "minimum": 0},
        "best_so_far": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "number"}
        },
        "coverage_method": {
          "enum": ["structural_proof", "small_complete_enumeration", "insertion_local_optimization", "independent_full_count_search"]
        },
        "coverage_details": {"type": "object"},
        "rounds": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["active_count", "evaluation_count", "best_exact"],
            "properties": {
              "active_count": {"type": "integer", "minimum": 0},
              "evaluation_count": {"type": "integer", "minimum": 1},
              "best_exact": {"type": "number"}
            }
          }
        },
        "consecutive_no_improvement_rounds": {"type": "integer", "minimum": 0},
        "incumbent_exact": {"type": "number"},
        "challenge_best_exact": {"type": "number"},
        "verdict": {"enum": ["incumbent_competitive", "incumbent_not_competitive", "inconclusive"]}
      }
    },
    "fixedActionUtilization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "question_id",
        "required_action_count",
        "full_objective",
        "marginal_gains",
        "tolerance",
        "all_required_actions_material",
        "verdict"
      ],
      "properties": {
        "question_id": {"type": "string", "minLength": 1},
        "required_action_count": {"type": "integer", "minimum": 1},
        "full_objective": {"type": "number"},
        "marginal_gains": {
          "type": "array",
          "items": {"type": "number"}
        },
        "tolerance": {"type": "number", "minimum": 0},
        "all_required_actions_material": {"type": "boolean"},
        "verdict": {
          "enum": ["all_actions_material", "underutilized_required_action", "invalid"]
        }
      }
    }
  }
}
