{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://github.com/zhouwu97/shumozizi/schemas/result_registry.schema.json",
  "type": "object", "additionalProperties": false, "required": ["schema_name", "schema_version", "run_id", "results"],
  "properties": {"schema_name": {"const": "result_registry"}, "schema_version": {"const": "2.0"}, "run_id": {"type": "string", "minLength": 1}, "results": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["result_id", "question_id", "cycle", "status", "paper_allowed", "execution_record_id", "metric_spec_ids", "sealed_result_path", "result_seal_path", "supersedes_result_id"], "properties": {"result_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"}, "question_id": {"type": "string", "minLength": 1}, "cycle": {"enum": ["baseline", "primary", "robustness", "ablation"]}, "status": {"enum": ["candidate", "accepted", "rejected", "revoked", "superseded"]}, "paper_allowed": {"type": "boolean"}, "execution_record_id": {"type": "string"}, "metric_spec_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}, "sealed_result_path": {"type": ["string", "null"]}, "result_seal_path": {"type": ["string", "null"]}, "supersedes_result_id": {"type": ["string", "null"]}}}}}
}
