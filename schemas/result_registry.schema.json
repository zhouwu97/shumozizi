{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/result_registry.schema.json",
  "title": "MathModelAgent Result Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "results"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "run_id": { "type": "string", "minLength": 1 },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "result_id",
          "question_id",
          "cycle",
          "status",
          "paper_allowed",
          "execution_record_id",
          "metrics",
          "unit",
          "conclusion",
          "constraint_checks",
          "validation_checks",
          "baseline_result_id",
          "innovation_claim_ids",
          "innovation_evidence",
          "acceptance"
        ],
        "allOf": [
          {
            "if": {
              "properties": { "paper_allowed": { "const": true } },
              "required": ["paper_allowed"]
            },
            "then": { "properties": { "status": { "const": "accepted" } } }
          },
          {
            "if": {
              "properties": { "status": { "const": "accepted" } },
              "required": ["status"]
            },
            "then": {
              "properties": {
                "metrics": { "minProperties": 1 },
                "unit": { "minLength": 1 },
                "conclusion": { "minLength": 1 },
                "constraint_checks": {
                  "minItems": 1,
                  "items": { "properties": { "passed": { "const": true } } }
                },
                "validation_checks": {
                  "minItems": 1,
                  "items": { "properties": { "passed": { "const": true } } }
                },
                "acceptance": { "$ref": "#/$defs/acceptance" }
              }
            }
          },
          {
            "if": {
              "properties": { "cycle": { "const": "baseline" } },
              "required": ["cycle"]
            },
            "then": { "properties": { "baseline_result_id": { "const": null } } },
            "else": {
              "properties": {
                "baseline_result_id": {
                  "type": "string",
                  "pattern": "^[A-Za-z0-9._-]+$"
                }
              }
            }
          }
        ],
        "properties": {
          "result_id": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
          "question_id": { "type": "string", "minLength": 1 },
          "cycle": { "enum": ["baseline", "primary", "robustness", "ablation"] },
          "status": { "enum": ["candidate", "accepted", "rejected"] },
          "paper_allowed": { "type": "boolean" },
          "execution_record_id": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
          "metrics": {
            "type": "object",
            "additionalProperties": {
              "type": ["number", "integer", "string", "boolean", "null"]
            }
          },
          "unit": { "type": "string" },
          "conclusion": { "type": "string" },
          "constraint_checks": {
            "type": "array",
            "items": { "$ref": "#/$defs/check" }
          },
          "validation_checks": {
            "type": "array",
            "items": { "$ref": "#/$defs/check" }
          },
          "baseline_result_id": { "type": ["string", "null"] },
          "innovation_claim_ids": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" }
          },
          "innovation_evidence": {
            "type": "array",
            "items": { "$ref": "#/$defs/innovation_evidence" }
          },
          "acceptance": {
            "oneOf": [
              { "type": "null" },
              { "$ref": "#/$defs/acceptance" }
            ]
          }
        }
      }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check_id", "passed", "details"],
      "properties": {
        "check_id": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "passed": { "type": "boolean" },
        "details": { "type": "string", "minLength": 1 },
        "evidence_path": { "type": ["string", "null"] }
      }
    },
    "innovation_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_id", "evidence_result_id"],
      "properties": {
        "claim_id": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "evidence_result_id": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" }
      }
    },
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "accepted_by",
        "accepted_at",
        "execution_record_sha256",
        "admission_tool",
        "admission_version"
      ],
      "properties": {
        "accepted_by": { "type": "string", "minLength": 1 },
        "accepted_at": { "type": "string", "format": "date-time" },
        "execution_record_sha256": { "$ref": "#/$defs/sha256" },
        "admission_tool": { "const": "scripts/runtime/accept_result.py" },
        "admission_version": { "const": "1.0" }
      }
    }
  }
}
