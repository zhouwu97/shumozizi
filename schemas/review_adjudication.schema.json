{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/review_adjudication.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name", "schema_version", "run_id", "request_id", "stage",
    "state_revision", "review_report_sha256", "decisions", "unresolved_conflicts",
    "generated_by", "generated_at"
  ],
  "properties": {
    "schema_name": {"const": "review_adjudication"},
    "schema_version": {"const": "2.0"},
    "run_id": {"type": "string", "minLength": 1},
    "request_id": {"type": "string", "minLength": 1},
    "stage": {"enum": ["R1_MODELING", "R2_EXPERIMENT", "R3_PAPER_LOGIC", "R4_FORMAT_VISUAL", "R5_COMPREHENSIVE", "J0_FINAL_BLIND_JUDGE"]},
    "review_mode": {"enum": ["full_scientific", "targeted_recheck", "diff_check", "machine_check"]},
    "state_revision": {"type": "integer", "minimum": 0},
    "review_report_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "finding_id", "reviewer_severity", "main_decision", "decision_reason",
          "effective_severity", "gate_effect", "confirmation_evidence",
          "counter_evidence", "resolution_evidence_type", "effective_change_level", "affected_questions",
          "required_retests", "route_reapproval_required"
        ],
        "properties": {
          "finding_id": {"type": "string", "minLength": 1},
          "reviewer_severity": {"enum": ["P0", "P1", "P2", "P3"]},
          "main_decision": {"enum": ["accepted", "rejected", "accepted_as_advisory", "deferred_empirical", "needs_probe", "needs_second_review", "needs_human_decision"]},
          "effective_severity": {"enum": ["P0", "P1", "P2", "P3"]},
          "domain": {"enum": ["scientific", "machine"]},
          "verification_mode": {"enum": ["targeted_recheck", "diff_check", "machine_check", "human_decision", "none"]},
          "scientific_semantic_change": {"type": "boolean"},
          "reopen_justification": {"type": ["string", "null"], "minLength": 1},
          "gate_effect": {"enum": ["block", "warn", "none"]},
          "decision_reason": {"type": "string", "minLength": 1},
          "confirmation_evidence": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "counter_evidence": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "resolution_evidence_type": {
            "type": ["string", "null"],
            "enum": [
              null,
              "deterministic_machine_evidence", "exact_oracle", "probe_result",
              "independent_second_review", "human_decision", "main_ai_opinion",
              "general_reasoning", "author_claim"
            ]
          },
          "effective_change_level": {"enum": ["L0", "L1", "L2", "L3", "L4", "L5"]},
          "affected_questions": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "required_retests": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "route_reapproval_required": {"type": "boolean"}
        }
      }
    },
    "unresolved_conflicts": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "adjudication_sequence": {"type": "integer", "minimum": 1},
    "supersedes_adjudication_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "probe_result_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "generated_by": {"const": "production_main_ai"},
    "generated_at": {"type": "string", "format": "date-time"}
  }
}
