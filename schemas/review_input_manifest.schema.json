{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/review_input_manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_name", "schema_version", "request_id", "run_id", "stage", "review_round_id", "state_revision", "materials", "forbidden_patterns", "generated_at"],
  "properties": {
    "schema_name": {"const": "review_input_manifest"},
    "schema_version": {"const": "2.0"},
    "request_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "stage": {"enum": ["R1_MODELING", "R2_EXPERIMENT", "R3_PAPER_LOGIC", "R4_FORMAT_VISUAL", "R5_COMPREHENSIVE", "J0_FINAL_BLIND_JUDGE"]},
    "review_round_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
    "state_revision": {"type": "integer", "minimum": 0},
    "materials": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "path", "sha256", "required", "visibility"],
        "properties": {
          "role": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "required": {"type": "boolean"},
          "visibility": {"const": "reviewer"}
        }
      }
    },
    "forbidden_patterns": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "generated_at": {"type": "string", "format": "date-time"}
  }
}
