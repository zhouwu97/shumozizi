{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/review_report.schema.json",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "coverage_status": {"enum": ["verified", "challenged", "unknown", "not_applicable"]},
    "axis_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "evidence"],
      "properties": {
        "status": {"$ref": "#/$defs/coverage_status"},
        "evidence": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    },
    "coverage_v3": {
      "type": "object",
      "properties": {
        "problem_interpretation": {"$ref": "#/$defs/coverage_status"},
        "question_output_mapping": {"$ref": "#/$defs/coverage_status"},
        "variable_completeness": {"$ref": "#/$defs/coverage_status"},
        "data_and_attachment_mapping": {"$ref": "#/$defs/coverage_status"},
        "unit_consistency": {"$ref": "#/$defs/coverage_status"},
        "equation_closure": {"$ref": "#/$defs/coverage_status"},
        "parameter_identifiability": {"$ref": "#/$defs/coverage_status"},
        "objective_definition": {"$ref": "#/$defs/coverage_status"},
        "constraint_completeness": {"$ref": "#/$defs/coverage_status"},
        "algorithm_executability": {"$ref": "#/$defs/coverage_status"},
        "stopping_rule": {"$ref": "#/$defs/coverage_status"},
        "baseline_design": {"$ref": "#/$defs/coverage_status"},
        "model_selection_criterion": {"$ref": "#/$defs/coverage_status"},
        "uncertainty_quantification": {"$ref": "#/$defs/coverage_status"},
        "robustness_and_ablation": {"$ref": "#/$defs/coverage_status"},
        "failure_boundary": {"$ref": "#/$defs/coverage_status"},
        "evidence_plan": {"$ref": "#/$defs/coverage_status"}
      }
    },
    "reviewer_finding_v2": {"type": "object", "additionalProperties": false, "required": ["finding_id", "severity", "title", "evidence", "remediation", "change_level", "affected_questions", "change_class", "route_impact", "changed_route_core_fields"], "properties": {"finding_id": {"type": "string"}, "severity": {"enum": ["P0", "P1", "P2", "P3"]}, "title": {"type": "string"}, "evidence": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "remediation": {"type": "string"}, "status": {"enum": ["open", "fixed", "accepted-risk"]}, "axis": {"enum": ["integrity", "quality", "both", "execution_reproducibility", "scientific_correctness"]}, "check_id": {"type": "string", "minLength": 1}, "recommended_resolution": {"enum": ["needs_probe", "needs_second_review", "needs_human_decision"]}, "affected_stage": {"type": "string"}, "affected_files": {"type": "array", "items": {"type": "string"}}, "affected_questions": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "change_level": {"enum": ["L0", "L1", "L2", "L3", "L4", "L5"]}, "required_retests": {"type": "array", "items": {"type": "string"}}, "expected_improvement": {"type": "string"}, "change_class": {"enum": ["SPEC_CLARIFICATION", "SPEC_COMPLETION", "IMPLEMENTATION_DETAIL", "VALIDATION_DETAIL", "EVIDENCE_METADATA", "EXPERIMENT_DESIGN_CHANGE", "ROUTE_CORE_CHANGE", "PROBLEM_INTERPRETATION_CHANGE"]}, "route_impact": {"enum": ["none", "material"]}, "changed_route_core_fields": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}}},
    "reviewer_finding_v3": {
      "type": "object",
      "additionalProperties": false,
      "required": ["finding_id", "severity_recommendation", "title", "claim", "evidence", "why_it_may_be_wrong"],
      "properties": {
        "finding_id": {"type": "string", "minLength": 1},
        "severity_recommendation": {"enum": ["P0", "P1", "P2", "P3"]},
        "title": {"type": "string", "minLength": 1},
        "claim": {"type": "string", "minLength": 1},
        "evidence": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "why_it_may_be_wrong": {"type": "string", "minLength": 1},
        "confidence": {"enum": ["low", "medium", "high"]},
        "status": {"enum": ["open", "deferred_empirical"]},
        "block_before": {"enum": ["formal_experiment", "model_selection", "paper_claim", "final_submission"]},
        "closure_condition": {"type": "string", "minLength": 1},
        "failure_action": {"type": "string", "minLength": 1},
        "reopen_context": {
          "type": "object",
          "additionalProperties": false,
          "required": ["relation_to_change", "previously_undiscoverable_reason", "reopen_evidence", "reopen_justification"],
          "properties": {
            "relation_to_change": {"type": "string", "minLength": 1},
            "previously_undiscoverable_reason": {"type": "string", "minLength": 1},
            "reopen_evidence": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
            "reopen_justification": {"type": "string", "minLength": 1}
          }
        },
        "check_id": {"type": ["string", "null"], "minLength": 1},
        "recommended_resolution": {"enum": ["needs_probe", "needs_second_review", "needs_human_decision"]}
      },
      "allOf": [
        {
          "if": {"required": ["status"], "properties": {"status": {"const": "deferred_empirical"}}},
          "then": {"required": ["block_before", "closure_condition", "failure_action"]}
        }
      ]
    }
  },
  "required": ["schema_name", "schema_version", "request_id", "run_id", "stage", "review_round_id", "request_sha256", "input_manifest_sha256", "session_sha256", "verdict", "findings", "read_only_confirmed", "generated_at"],
  "properties": {
    "schema_name": {"const": "review_report"},
    "schema_version": {"enum": ["2.0", "3.0"]},
    "request_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "stage": {"enum": ["R1_MODELING", "R2_EXPERIMENT", "R3_PAPER_LOGIC", "R4_FORMAT_VISUAL", "R5_COMPREHENSIVE", "J0_FINAL_BLIND_JUDGE"]},
    "review_mode": {"enum": ["full_scientific", "targeted_recheck", "diff_check", "machine_check"]},
    "target_finding_id": {"type": "string", "minLength": 1},
    "review_round_id": {"type": "string", "minLength": 1},
    "request_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "input_manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "session_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "verdict": {"type": "string", "minLength": 1},
    "findings": {"type": "array"},
    "phase_a_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "coverage": {"type": "object", "additionalProperties": false, "required": ["problem_interpretation", "question_output_mapping", "variable_completeness", "data_and_attachment_mapping", "unit_consistency", "equation_closure", "parameter_identifiability", "objective_definition", "constraint_completeness", "algorithm_executability", "stopping_rule", "baseline_design", "model_selection_criterion", "uncertainty_quantification", "robustness_and_ablation", "failure_boundary", "evidence_plan", "unchecked_items"], "properties": {"problem_interpretation": {"enum": ["pass", "fail", "verified", "challenged", "unknown", "not_applicable"]}, "question_output_mapping": {"enum": ["pass", "fail", "verified", "challenged", "unknown", "not_applicable"]}, "variable_completeness": {"enum": ["pass", "fail", "verified", "challenged", "unknown", "not_applicable"]}, "data_and_attachment_mapping": {"enum": ["pass", "fail", "verified", "challenged", "unknown", "not_applicable"]}, "unit_consistency": {"enum": ["pass", "fail", "verified", "challenged", "unknown", "not_applicable"]}, "equation_closure": {"enum": ["pass", "fail", "verified", "challenged", "unknown", "not_applicable"]}, "parameter_identifiability": {"enum": ["pass", "fail", "verified", "challenged", "unknown", "not_applicable"]}, "objective_definition": {"enum": ["pass", "fail", "verified", "challenged", "unknown", "not_applicable"]}, "constraint_completeness": {"enum": ["pass", "fail", "verified", "challenged", "unknown", "not_applicable"]}, "algorithm_executability": {"enum": ["pass", "fail", "verified", "challenged", "unknown", "not_applicable"]}, "stopping_rule": {"enum": ["pass", "fail", "verified", "challenged", "unknown", "not_applicable"]}, "baseline_design": {"enum": ["pass", "fail", "verified", "challenged", "unknown", "not_applicable"]}, "model_selection_criterion": {"enum": ["pass", "fail", "verified", "challenged", "unknown", "not_applicable"]}, "uncertainty_quantification": {"enum": ["pass", "fail", "verified", "challenged", "unknown", "not_applicable"]}, "robustness_and_ablation": {"enum": ["pass", "fail", "verified", "challenged", "unknown", "not_applicable"]}, "failure_boundary": {"enum": ["pass", "fail", "verified", "challenged", "unknown", "not_applicable"]}, "evidence_plan": {"enum": ["pass", "fail", "verified", "challenged", "unknown", "not_applicable"]}, "unchecked_items": {"type": "array", "maxItems": 0, "items": {"type": "string"}}}},
    "execution_reproducibility": {"type": "object", "additionalProperties": false, "required": ["status", "checks"], "properties": {"status": {"$ref": "#/$defs/coverage_status"}, "checks": {"type": "object", "additionalProperties": false, "required": ["code_execution", "config_reproducibility", "hash_integrity", "random_seed_control", "result_figure_consistency", "accepted_result_seal"], "properties": {"code_execution": {"$ref": "#/$defs/axis_check"}, "config_reproducibility": {"$ref": "#/$defs/axis_check"}, "hash_integrity": {"$ref": "#/$defs/axis_check"}, "random_seed_control": {"$ref": "#/$defs/axis_check"}, "result_figure_consistency": {"$ref": "#/$defs/axis_check"}, "accepted_result_seal": {"$ref": "#/$defs/axis_check"}}}}},
    "scientific_correctness": {"type": "object", "additionalProperties": false, "required": ["status", "checks"], "properties": {"status": {"$ref": "#/$defs/coverage_status"}, "checks": {"type": "object", "additionalProperties": false, "required": ["split_design", "leakage_control", "metric_suitability", "constraint_completeness", "solution_credibility", "parameter_stability", "conclusion_bounds", "robustness_discrimination"], "properties": {"split_design": {"$ref": "#/$defs/axis_check"}, "leakage_control": {"$ref": "#/$defs/axis_check"}, "metric_suitability": {"$ref": "#/$defs/axis_check"}, "constraint_completeness": {"$ref": "#/$defs/axis_check"}, "solution_credibility": {"$ref": "#/$defs/axis_check"}, "parameter_stability": {"$ref": "#/$defs/axis_check"}, "conclusion_bounds": {"$ref": "#/$defs/axis_check"}, "robustness_discrimination": {"$ref": "#/$defs/axis_check"}}}}},
    "preregistered_oracles": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["oracle_id", "oracle_type", "question", "registered_before_primary", "success_condition", "evidence_path"], "properties": {"oracle_id": {"type": "string", "minLength": 1}, "oracle_type": {"enum": ["exact_solution", "small_instance_exhaustive_solution", "synthetic_recovery", "independent_implementation", "known_limiting_case", "permutation_null", "multiple_start_consistency", "grid_convergence", "constraint_feasibility_oracle"]}, "question": {"type": "string", "minLength": 1}, "registered_before_primary": {"const": true}, "success_condition": {"type": "string", "minLength": 1}, "evidence_path": {"type": "string", "minLength": 1}}}},
    "rating": {"type": "object", "additionalProperties": false, "required": ["grade", "confidence", "basis", "downgrade_reasons", "expert_estimate"], "properties": {"grade": {"enum": ["A", "B", "C", "D", "E"]}, "confidence": {"enum": ["low", "medium", "high"]}, "basis": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "downgrade_reasons": {"type": "array", "items": {"type": "string"}}, "expert_estimate": {"const": true}}},
    "integrity_axis": {"type": "object", "additionalProperties": false, "required": ["verdict", "checks", "blockers"], "properties": {"verdict": {"enum": ["A_PASS", "A_BLOCKED"]}, "checks": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "blockers": {"type": "array", "items": {"type": "string"}}}},
    "score_type": {"const": "competition_quality"},
    "assessment_scope": {"const": "full_competition_submission"},
    "raw_score": {"type": "number", "minimum": 0, "maximum": 100},
    "calibrated_score": {"type": "number", "minimum": 0, "maximum": 100},
    "score_caps_applied": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["cap_id", "reason"],
        "properties": {
          "cap_id": {"type": "string", "minLength": 1},
          "reason": {"type": "string", "minLength": 1},
          "maximum_score": {"type": ["number", "null"], "minimum": 0, "maximum": 100},
          "dimension": {"enum": ["problem_coverage", "model_depth", "experiment_validation"]},
          "maximum_dimension": {"type": "number", "minimum": 0, "maximum": 100}
        }
      }
    },
    "competition_claim_allowed": {"type": "boolean"},
    "quality_axis": {"type": "object", "additionalProperties": false, "required": ["verdict", "raw_dimensions", "dimensions", "evidence"], "properties": {"verdict": {"enum": ["B_STRONG", "B_PASS", "B_WEAK", "B_REBUILD"]}, "raw_dimensions": {"type": "object", "required": ["problem_coverage", "model_depth", "experiment_validation"], "additionalProperties": {"type": "number", "minimum": 0, "maximum": 100}}, "dimensions": {"type": "object", "required": ["problem_coverage", "model_depth", "experiment_validation"], "additionalProperties": {"type": "number", "minimum": 0, "maximum": 100}}, "evidence": {"type": "array", "minItems": 1, "items": {"type": "string"}}}},
    "joint_verdict": {"enum": ["FINAL_CANDIDATE", "QUALITY_REPAIR", "INTEGRITY_REPAIR", "FULL_REPAIR"]},
    "repair_scope": {"type": "array", "items": {"type": "string"}},
    "required_retests": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "read_only_confirmed": {"const": true},
    "generated_at": {"type": "string", "format": "date-time"}
  },
  "allOf": [
    {"if": {"properties": {"schema_version": {"const": "2.0"}}}, "then": {"properties": {"findings": {"items": {"$ref": "#/$defs/reviewer_finding_v2"}}}}},
    {"if": {"properties": {"schema_version": {"const": "3.0"}}}, "then": {"properties": {"findings": {"items": {"$ref": "#/$defs/reviewer_finding_v3"}}}}},
    {"if": {"allOf": [{"properties": {"stage": {"const": "R1_MODELING"}}}, {"anyOf": [{"not": {"required": ["review_mode"]}}, {"properties": {"review_mode": {"const": "full_scientific"}}}]}]}, "then": {"required": ["coverage"]}},
    {"if": {"allOf": [{"properties": {"stage": {"const": "R1_MODELING"}, "schema_version": {"const": "3.0"}}}, {"anyOf": [{"not": {"required": ["review_mode"]}}, {"properties": {"review_mode": {"const": "full_scientific"}}}]}]}, "then": {"required": ["phase_a_sha256"], "properties": {"coverage": {"$ref": "#/$defs/coverage_v3"}}}},
    {"if": {"allOf": [{"properties": {"stage": {"const": "R2_EXPERIMENT"}, "schema_version": {"const": "3.0"}}}, {"anyOf": [{"not": {"required": ["review_mode"]}}, {"properties": {"review_mode": {"const": "full_scientific"}}}]}]}, "then": {"required": ["execution_reproducibility", "scientific_correctness", "preregistered_oracles"]}},
    {"if": {"allOf": [{"properties": {"stage": {"const": "R5_COMPREHENSIVE"}}}, {"anyOf": [{"not": {"required": ["review_mode"]}}, {"properties": {"review_mode": {"const": "full_scientific"}}}]}]}, "then": {"required": ["rating", "integrity_axis", "score_type", "assessment_scope", "raw_score", "calibrated_score", "score_caps_applied", "competition_claim_allowed", "quality_axis", "joint_verdict", "repair_scope", "required_retests"]}}
  ]
}
