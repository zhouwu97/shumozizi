{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/review_report.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_name", "schema_version", "request_id", "run_id", "stage", "review_round_id", "verdict", "findings", "read_only_confirmed", "generated_at"],
  "properties": {
    "schema_name": {"const": "review_report"},
    "schema_version": {"const": "2.0"},
    "request_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "stage": {"enum": ["R1_MODELING", "R2_EXPERIMENT", "R3_PAPER_LOGIC", "R4_FORMAT_VISUAL", "R5_COMPREHENSIVE"]},
    "review_round_id": {"type": "string", "minLength": 1},
    "verdict": {"type": "string", "minLength": 1},
    "findings": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["finding_id", "severity", "title", "evidence", "remediation"], "properties": {"finding_id": {"type": "string"}, "severity": {"enum": ["P0", "P1", "P2", "P3"]}, "title": {"type": "string"}, "evidence": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "remediation": {"type": "string"}, "status": {"enum": ["open", "fixed", "accepted-risk"]}}}},
    "rating": {"type": "object", "additionalProperties": false, "required": ["grade", "confidence", "basis", "downgrade_reasons", "expert_estimate"], "properties": {"grade": {"enum": ["A", "B", "C", "D", "E"]}, "confidence": {"enum": ["low", "medium", "high"]}, "basis": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "downgrade_reasons": {"type": "array", "items": {"type": "string"}}, "expert_estimate": {"const": true}}},
    "read_only_confirmed": {"const": true},
    "generated_at": {"type": "string", "format": "date-time"}
  },
  "allOf": [{"if": {"properties": {"stage": {"const": "R5_COMPREHENSIVE"}}}, "then": {"required": ["rating"]}}]
}
