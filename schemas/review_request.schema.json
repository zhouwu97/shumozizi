{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/review_request.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_name", "schema_version", "request_id", "run_id", "stage", "review_round_id", "state_revision", "bindings", "binding_paths", "read_paths", "mandatory_inputs", "optional_inputs", "forbidden_inputs", "required_outputs", "hard_blocks", "quality_dimensions", "output_path", "skill", "read_only", "budget", "requested_at"],
  "properties": {
    "schema_name": {"const": "review_request"},
    "schema_version": {"const": "2.0"},
    "request_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "stage": {"enum": ["R1_MODELING", "R2_EXPERIMENT", "R3_PAPER_LOGIC", "R4_FORMAT_VISUAL", "R5_COMPREHENSIVE", "J0_FINAL_BLIND_JUDGE"]},
    "question_id": {"type": ["string", "null"]},
    "review_round_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
    "state_revision": {"type": "integer", "minimum": 0},
    "bindings": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "string", "pattern": "^[a-f0-9]{64}$"}},
    "binding_paths": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "string", "minLength": 1}},
    "read_paths": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "mandatory_inputs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "optional_inputs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "forbidden_inputs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "required_outputs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "hard_blocks": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "quality_dimensions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "output_path": {"type": "string", "minLength": 1},
    "skill": {"type": "string", "minLength": 1},
    "read_only": {"const": true},
    "budget": {"type": "object", "required": ["max_minutes", "max_rounds"], "additionalProperties": false, "properties": {"max_minutes": {"type": "integer", "minimum": 1}, "max_rounds": {"type": "integer", "minimum": 1, "maximum": 5}}},
    "requested_at": {"type": "string", "format": "date-time"}
  }
}
