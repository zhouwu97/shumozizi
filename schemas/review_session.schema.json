{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/review_session.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_name", "schema_version", "run_id", "request_id", "review_round_id", "stage", "state_revision", "executor", "execution_policy", "attestation_level", "request_sha256", "input_manifest_sha256", "claimed_at", "started_at"],
  "properties": {
    "schema_name": {"const": "review_session"},
    "schema_version": {"const": "2.0"},
    "run_id": {"type": "string", "minLength": 1},
    "request_id": {"type": "string", "minLength": 1},
    "review_round_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
    "stage": {"enum": ["R1_MODELING", "R2_EXPERIMENT", "R3_PAPER_LOGIC", "R4_FORMAT_VISUAL", "R5_COMPREHENSIVE", "J0_FINAL_BLIND_JUDGE"]},
    "state_revision": {"type": "integer", "minimum": 0},
    "executor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform", "thread_id", "task_kind", "parent_thread_id"],
      "properties": {
        "platform": {"const": "codex_desktop"},
        "thread_id": {"type": "string", "minLength": 1},
        "task_kind": {"const": "top_level"},
        "parent_thread_id": {"type": "null"}
      }
    },
    "execution_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["new_thread", "subagent", "forked", "context_inherited"],
      "properties": {
        "new_thread": {"const": true},
        "subagent": {"const": false},
        "forked": {"const": false},
        "context_inherited": {"const": false}
      }
    },
    "attestation_level": {"enum": ["self_declared", "orchestrator_verified", "platform_verified"]},
    "request_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "input_manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "claimed_at": {"type": "string", "format": "date-time"},
    "started_at": {"type": "string", "format": "date-time"}
  }
}
