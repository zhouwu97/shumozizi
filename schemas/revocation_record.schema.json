{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://github.com/zhouwu97/shumozizi/schemas/revocation_record.schema.json",
  "type": "object", "additionalProperties": false, "required": ["schema_name", "schema_version", "run_id", "result_id", "previous_result_sha256", "reason", "status", "revoked_by", "revoked_at"],
  "properties": {"schema_name": {"const": "revocation_record"}, "schema_version": {"const": "2.0"}, "run_id": {"type": "string"}, "result_id": {"type": "string"}, "previous_result_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "reason": {"type": "string", "minLength": 1}, "status": {"enum": ["revoked", "superseded"]}, "superseded_by": {"type": ["string", "null"]}, "revoked_by": {"type": "string"}, "revoked_at": {"type": "string", "format": "date-time"}}
}
