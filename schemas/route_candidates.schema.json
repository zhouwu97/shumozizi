{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/route_candidates.schema.json",
  "title": "MathModelAgent Route Candidates",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "problem_summary", "ambiguities", "recommended_route_id", "candidates"],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "problem_summary": { "type": "string", "minLength": 20 },
    "ambiguities": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "recommended_route_id": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
    "recommendation_reason": { "type": "string", "minLength": 10 },
    "candidates": {
      "type": "array",
      "minItems": 2,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "route_id",
          "name",
          "problem_interpretation",
          "mathematical_nature",
          "baseline",
          "primary_model",
          "innovation",
          "validation",
          "computational_cost",
          "risks",
          "fallback"
        ],
        "properties": {
          "route_id": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
          "name": { "type": "string", "minLength": 2 },
          "problem_interpretation": { "type": "string", "minLength": 10 },
          "mathematical_nature": { "type": "string", "minLength": 2 },
          "baseline": { "type": "string", "minLength": 2 },
          "primary_model": { "type": "string", "minLength": 2 },
          "innovation": { "type": "string", "minLength": 2 },
          "validation": { "type": "string", "minLength": 2 },
          "computational_cost": { "type": "string", "minLength": 2 },
          "risks": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "fallback": { "type": "string", "minLength": 2 }
        }
      }
    }
  }
}
