{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/route_candidates.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_name",
    "schema_version",
    "run_id",
    "run_config_lock_sha256",
    "problem_summary",
    "ambiguities",
    "recommended_route_id",
    "candidates"
  ],
  "allOf": [
    {
      "if": {
        "required": ["ambiguity_review", "material_ambiguities"],
        "properties": {"material_ambiguities": {"maxItems": 0}}
      },
      "then": {
        "properties": {
          "ambiguity_review": {"required": ["none_reason"]}
        }
      }
    }
  ],
  "properties": {
    "schema_name": {"const": "route_candidates"},
    "schema_version": {"const": "2.0"},
    "run_id": {"type": "string", "minLength": 1},
    "run_config_lock_sha256": {"$ref": "#/$defs/sha"},
    "problem_summary": {"type": "string", "minLength": 20},
    "ambiguities": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "ambiguity_review": {"$ref": "#/$defs/ambiguity_review"},
    "material_ambiguities": {
      "type": "array",
      "items": {"$ref": "#/$defs/material_ambiguity"}
    },
    "recommended_route_id": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
    "recommendation_reason": {"type": "string", "minLength": 10},
    "candidates": {
      "type": "array",
      "minItems": 2,
      "maxItems": 3,
      "items": {"$ref": "#/$defs/candidate"}
    }
  },
  "$defs": {
    "sha": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "ambiguity_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["performed"],
      "properties": {
        "performed": {"const": true},
        "none_reason": {"type": "string", "minLength": 10}
      }
    },
    "material_ambiguity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ambiguity_id",
        "statement",
        "alternatives",
        "selected_interpretation",
        "selection_reason",
        "impact_if_wrong"
      ],
      "properties": {
        "ambiguity_id": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
        "statement": {"type": "string", "minLength": 10},
        "alternatives": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["interpretation", "supporting_evidence", "consequences"],
            "properties": {
              "interpretation": {"type": "string", "minLength": 1},
              "supporting_evidence": {"type": "array", "items": {"type": "string"}},
              "consequences": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "string", "minLength": 1}
              }
            }
          }
        },
        "selected_interpretation": {"type": "string", "minLength": 1},
        "selection_reason": {"type": "string", "minLength": 10},
        "impact_if_wrong": {"type": "string", "minLength": 10}
      }
    },
    "mechanism_signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_object",
        "core_assumptions",
        "relation_form",
        "uncertainty_treatment",
        "decision_rule",
        "expected_advantage",
        "failure_boundary"
      ],
      "properties": {
        "decision_object": {"type": "string", "minLength": 2},
        "core_assumptions": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "relation_form": {"type": "string", "minLength": 2},
        "uncertainty_treatment": {"type": "string", "minLength": 2},
        "decision_rule": {"type": "string", "minLength": 2},
        "expected_advantage": {"type": "string", "minLength": 2},
        "failure_boundary": {"type": "string", "minLength": 2}
      }
    },
    "prediction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prediction_id", "metric", "expected_direction"],
      "properties": {
        "prediction_id": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
        "metric": {"type": "string", "minLength": 1},
        "expected_direction": {
          "enum": [
            "increase",
            "decrease",
            "not_decrease_beyond",
            "not_increase_beyond",
            "stable"
          ]
        },
        "minimum_effect": {"type": "number"},
        "maximum_effect": {"type": "number"},
        "maximum_relative_loss": {"type": "number", "minimum": 0}
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "expected_direction": {"enum": ["increase", "decrease"]}
            }
          },
          "then": {"required": ["minimum_effect"]}
        },
        {
          "if": {
            "properties": {
              "expected_direction": {
                "enum": ["not_decrease_beyond", "not_increase_beyond"]
              }
            }
          },
          "then": {"required": ["maximum_relative_loss"]}
        }
      ]
    },
    "comparison_predicate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "metric", "relation", "threshold", "unit", "aggregation"],
      "properties": {
        "prediction_id": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
        "role": {"enum": ["required_support", "falsification"]},
        "metric": {"type": "string", "minLength": 1},
        "relation": {
          "enum": [
            "relative_increase",
            "relative_decrease",
            "relative_decrease_at_most",
            "relative_increase_at_most",
            "absolute_increase",
            "absolute_decrease",
            "absolute_decrease_at_most",
            "absolute_increase_at_most",
            "stable"
          ]
        },
        "threshold": {"type": "number"},
        "unit": {"type": "string", "minLength": 1},
        "aggregation": {"type": "string", "minLength": 1}
      }
    },
    "innovation_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "claim",
        "mechanism",
        "baseline_difference",
        "testable_predictions",
        "falsified_if",
        "comparison_predicates",
        "required_experiment_roles"
      ],
      "properties": {
        "claim_id": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
        "claim": {"type": "string", "minLength": 2},
        "mechanism": {"type": "string", "minLength": 2},
        "baseline_difference": {"type": "string", "minLength": 2},
        "testable_predictions": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/prediction"}
        },
        "falsified_if": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "comparison_predicates": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/comparison_predicate"}
        },
        "required_experiment_roles": {
          "type": "array",
          "minItems": 1,
          "items": {"enum": ["baseline", "primary", "robustness", "ablation"]}
        },
        "paper_allowed_only_if_supported": {"type": "boolean"}
      }
    },
    "minimal_probe_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "purpose",
        "compared_routes",
        "data_scope",
        "budget_seconds",
        "metrics",
        "selection_rule"
      ],
      "properties": {
        "purpose": {"type": "string", "minLength": 2},
        "compared_routes": {
          "type": "array",
          "minItems": 2,
          "items": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"}
        },
        "data_scope": {"type": "string", "minLength": 2},
        "budget_seconds": {"type": "integer", "minimum": 1},
        "metrics": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "selection_rule": {"type": "string", "minLength": 10}
      }
    },
    "fallback_object": {
      "type": "object",
      "additionalProperties": false,
      "required": ["route_id", "trigger_conditions"],
      "properties": {
        "route_id": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
        "trigger_conditions": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_id",
        "name",
        "problem_interpretation",
        "mathematical_nature",
        "baseline",
        "primary_model",
        "innovation",
        "validation",
        "computational_cost",
        "risks",
        "fallback"
      ],
      "properties": {
        "route_id": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
        "name": {"type": "string", "minLength": 2},
        "problem_interpretation": {"type": "string", "minLength": 10},
        "mathematical_nature": {"type": "string", "minLength": 2},
        "baseline": {"type": "string", "minLength": 2},
        "primary_model": {"type": "string", "minLength": 2},
        "innovation": {"type": "string", "minLength": 2},
        "validation": {"type": "string", "minLength": 2},
        "computational_cost": {"type": "string", "minLength": 2},
        "risks": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "fallback": {
          "oneOf": [
            {"type": "string", "minLength": 2},
            {"$ref": "#/$defs/fallback_object"}
          ]
        },
        "mechanism_signature": {"$ref": "#/$defs/mechanism_signature"},
        "innovation_claims": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/innovation_claim"}
        },
        "minimal_probe_plan": {"$ref": "#/$defs/minimal_probe_plan"}
      }
    }
  }
}
