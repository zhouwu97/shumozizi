{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://github.com/zhouwu97/shumozizi/schemas/route_candidates.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_name", "schema_version", "run_id", "run_config_lock_sha256", "problem_summary", "ambiguities", "recommended_route_id", "candidates"],
  "properties": {
    "schema_name": {"const": "route_candidates"}, "schema_version": {"const": "2.0"},
    "run_id": {"type": "string", "minLength": 1}, "run_config_lock_sha256": {"$ref": "#/$defs/sha"},
    "problem_summary": {"type": "string", "minLength": 20}, "ambiguities": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "recommended_route_id": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"}, "recommendation_reason": {"type": "string", "minLength": 10},
    "candidates": {"type": "array", "minItems": 2, "maxItems": 3, "items": {"$ref": "#/$defs/candidate"}}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "candidate": {"type": "object", "additionalProperties": false, "required": ["route_id", "name", "problem_interpretation", "mathematical_nature", "baseline", "primary_model", "innovation", "validation", "computational_cost", "risks", "fallback"], "properties": {"route_id": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"}, "name": {"type": "string", "minLength": 2}, "problem_interpretation": {"type": "string", "minLength": 10}, "mathematical_nature": {"type": "string", "minLength": 2}, "baseline": {"type": "string", "minLength": 2}, "primary_model": {"type": "string", "minLength": 2}, "innovation": {"type": "string", "minLength": 2}, "validation": {"type": "string", "minLength": 2}, "computational_cost": {"type": "string", "minLength": 2}, "risks": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}, "fallback": {"type": "string", "minLength": 2}}}
  }
}
