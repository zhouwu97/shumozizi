{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://github.com/zhouwu97/shumozizi/schemas/route_lock.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_name", "schema_version", "run_id", "approved", "selected_route_id", "run_config_lock_sha256", "route_candidates_sha256", "approval_receipt_sha256", "problem_interpretation", "primary_route", "fallback_route", "required_baselines", "innovation_claims", "validation", "resource_limits", "approved_by", "approved_at"],
  "properties": {
    "schema_name": {"const": "route_lock"}, "schema_version": {"const": "2.0"}, "run_id": {"type": "string", "minLength": 1}, "approved": {"const": true},
    "selected_route_id": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"}, "run_config_lock_sha256": {"$ref": "#/$defs/sha"}, "route_candidates_sha256": {"$ref": "#/$defs/sha"}, "approval_receipt_sha256": {"$ref": "#/$defs/sha"},
    "problem_interpretation": {"type": "string", "minLength": 10}, "primary_route": {"type": "string", "minLength": 2}, "fallback_route": {"type": "string", "minLength": 2},
    "required_baselines": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "innovation_claims": {"type": "array", "items": {"type": "object", "required": ["claim_id", "claim"], "properties": {"claim_id": {"type": "string"}, "claim": {"type": "string"}}}},
    "validation": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "resource_limits": {"type": "object", "additionalProperties": false, "required": ["max_main_experiment_cycles_per_question", "max_web_searches", "max_full_self_reviews", "route_drift_budget_ratio"], "properties": {"max_main_experiment_cycles_per_question": {"type": "integer", "minimum": 1, "maximum": 3}, "max_web_searches": {"type": "integer", "minimum": 0, "maximum": 10}, "max_full_self_reviews": {"const": 1}, "route_drift_budget_ratio": {"type": "number", "exclusiveMinimum": 0, "maximum": 1}}},
    "approved_by": {"type": "string", "minLength": 1}, "approved_at": {"type": "string", "format": "date-time"}
  }, "$defs": {"sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
