{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/route_lock.schema.json",
  "title": "MathModelAgent Human Route Lock",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "approved",
    "selected_route_id",
    "problem_interpretation",
    "primary_route",
    "fallback_route",
    "required_baselines",
    "innovation",
    "validation",
    "resource_limits"
  ],
  "properties": {
    "approved": { "const": true },
    "selected_route_id": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
    "problem_interpretation": { "type": "string", "minLength": 10 },
    "primary_route": { "type": "string", "minLength": 2 },
    "fallback_route": { "type": "string", "minLength": 2 },
    "required_baselines": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "innovation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["major_per_question", "minor_per_question", "claims"],
      "properties": {
        "major_per_question": { "type": "integer", "minimum": 0, "maximum": 1 },
        "minor_per_question": { "type": "integer", "minimum": 0, "maximum": 1 },
        "claims": { "type": "array", "items": { "type": "string" } }
      }
    },
    "validation": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "resource_limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_main_experiment_cycles_per_question", "max_web_searches", "max_full_self_reviews", "route_drift_budget_ratio"],
      "properties": {
        "max_main_experiment_cycles_per_question": { "type": "integer", "minimum": 1, "maximum": 3 },
        "max_web_searches": { "type": "integer", "minimum": 0, "maximum": 10 },
        "max_full_self_reviews": { "const": 1 },
        "route_drift_budget_ratio": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
      }
    },
    "approved_by": { "type": "string", "minLength": 1 },
    "approved_at": { "type": "string", "format": "date-time" }
  }
}
