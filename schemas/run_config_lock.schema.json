{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://github.com/zhouwu97/shumozizi/schemas/run_config_lock.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_name", "schema_version", "lock_version", "run_id", "competition_profile", "paper_engine", "language", "anonymous", "problem_source_sha256", "locked_at"],
  "properties": {"schema_name": {"const": "run_config_lock"}, "schema_version": {"const": "2.0"}, "lock_version": {"type": "integer", "minimum": 1}, "run_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"}, "competition_profile": {"type": "object", "additionalProperties": false, "required": ["profile_id", "profile_version", "profile_path", "profile_sha256"], "properties": {"profile_id": {"type": "string"}, "profile_version": {"type": "string"}, "profile_path": {"type": "string"}, "profile_sha256": {"$ref": "#/$defs/sha"}}}, "paper_engine": {"const": "typst"}, "language": {"enum": ["zh", "en"]}, "anonymous": {"type": "boolean"}, "problem_source_sha256": {"$ref": "#/$defs/sha"}, "locked_at": {"type": "string", "format": "date-time"}},
  "$defs": {"sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
