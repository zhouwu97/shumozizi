{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/scientific_reviewer_cases.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_name", "schema_version", "benchmark_id", "development_use", "rule_tuning_prohibited", "cases"],
  "properties": {
    "schema_name": {"const": "scientific_reviewer_cases"},
    "schema_version": {"const": "1.0"},
    "benchmark_id": {"type": "string", "minLength": 1},
    "development_use": {"const": "held_out_independent_review_only"},
    "rule_tuning_prohibited": {"const": true},
    "cases": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "required_review_stages", "problem_fragment", "data_or_fixture", "model_spec", "experiment_plan", "code_or_pseudocode"],
        "properties": {
          "case_id": {"type": "string", "pattern": "^RV-[0-9]{2}-[a-z0-9-]+$"},
          "required_review_stages": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["R1_MODELING", "R2_EXPERIMENT"]}},
          "problem_fragment": {"type": "string", "minLength": 1},
          "data_or_fixture": {"type": "string", "minLength": 1},
          "model_spec": {"type": "string", "minLength": 1},
          "experiment_plan": {"type": "string", "minLength": 1},
          "code_or_pseudocode": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
