{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://github.com/zhouwu97/shumozizi/schemas/sealed_result.schema.json",
  "type": "object", "additionalProperties": false, "required": ["schema_name", "schema_version", "result_id", "run_id", "question_id", "cycle", "execution_record_id", "metrics", "conclusion", "constraint_checks", "validation_checks", "baseline_result_id", "paper_allowed", "accepted_by", "accepted_at"],
  "anyOf": [{"required": ["claim_refs"]}, {"required": ["innovation_claims"]}],
  "properties": {"schema_name": {"const": "sealed_result"}, "schema_version": {"const": "2.0"}, "result_id": {"type": "string"}, "run_id": {"type": "string"}, "question_id": {"type": "string"}, "cycle": {"enum": ["baseline", "primary", "robustness", "ablation"]}, "execution_record_id": {"type": "string"}, "metrics": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["name", "metric_spec_id", "value", "unit"], "properties": {"name": {"type": "string"}, "metric_spec_id": {"type": "string"}, "value": {}, "unit": {"type": "string"}}}}, "conclusion": {"type": "string", "minLength": 1}, "constraint_checks": {"type": "array", "minItems": 1}, "validation_checks": {"type": "array", "minItems": 1}, "baseline_result_id": {"type": ["string", "null"]}, "claim_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "innovation_claims": {"type": "array", "items": {"type": "object", "required": ["claim_id", "claim", "evidence", "status"], "properties": {"claim_id": {"type": "string"}, "claim": {"type": "string"}, "evidence": {"type": "array", "items": {"type": "object", "required": ["result_id", "metric_spec_ids", "relation"], "properties": {"result_id": {"type": "string"}, "metric_spec_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "relation": {"enum": ["supports", "contradicts", "qualifies"]}}}}, "status": {"enum": ["keep", "drop", "revise"]}}}}, "paper_allowed": {"type": "boolean"}, "accepted_by": {"type": "string"}, "accepted_at": {"type": "string", "format": "date-time"}}
}
