{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/simple_review_summary.schema.json",
  "title": "Capability-First v3 Independent Review Summary",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "scientific_review", "paper_blind_review", "updated_at"],
  "properties": {
    "schema_version": {"enum": ["1.0", "1.1", "1.2", "1.3", "1.4", "1.5", "1.6"]},
    "run_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
    "scientific_review": {"$ref": "#/$defs/scientificReview"},
    "paper_blind_review": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/paperBlindReview"}]},
    "final_audit": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/finalAudit"}]},
    "updated_at": {"type": "string", "format": "date-time"}
  },
  "allOf": [
    {
      "if": {"properties": {"schema_version": {"const": "1.1"}}},
      "then": {"properties": {"scientific_review": {"required": ["artifacts"]}}}
    },
    {
      "if": {"properties": {"schema_version": {"const": "1.2"}}},
      "then": {
        "properties": {
          "scientific_review": {
            "required": ["artifacts"],
            "properties": {
              "artifacts": {"required": ["receipts", "report_citations", "evidence_kinds"]}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"schema_version": {"const": "1.3"}}},
      "then": {
        "required": ["final_audit"],
        "properties": {
          "scientific_review": {
            "required": ["artifacts"],
            "properties": {
              "artifacts": {"required": ["receipts", "report_citations", "evidence_kinds"]}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"schema_version": {"const": "1.4"}}},
      "then": {
        "required": ["final_audit"],
        "properties": {
          "scientific_review": {
            "required": ["artifacts"],
            "properties": {
              "artifacts": {"required": ["receipts", "report_citations", "evidence_kinds"]}
            }
          },
          "paper_blind_review": {
            "oneOf": [
              {"type": "null"},
              {"$ref": "#/$defs/paperBlindReviewV14"}
            ]
          }
        }
      }
    },
    {
      "if": {"properties": {"schema_version": {"const": "1.5"}}},
      "then": {
        "required": ["final_audit"],
        "properties": {
          "scientific_review": {
            "required": ["artifacts", "objective_semantics"],
            "properties": {
              "artifacts": {"required": ["receipts", "report_citations", "evidence_kinds"]}
            }
          },
          "paper_blind_review": {
            "oneOf": [
              {"type": "null"},
              {"$ref": "#/$defs/paperBlindReviewV14"}
            ]
          }
        }
      }
    },
    {
      "if": {"properties": {"schema_version": {"const": "1.6"}}},
      "then": {
        "required": ["final_audit"],
        "properties": {
          "scientific_review": {
            "required": ["artifacts", "objective_semantics", "question_reviews"],
            "properties": {
              "artifacts": {"required": ["receipts", "report_citations", "evidence_kinds"]}
            }
          },
          "paper_blind_review": {
            "oneOf": [
              {"type": "null"},
              {"$ref": "#/$defs/paperBlindReviewV14"}
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "findingLevel": {"enum": ["none", "P0", "P1", "P2", "P3"]},
    "verdict": {"enum": ["pass", "fail", "needs_rework", "revoked"]},
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha"}
      }
    },
    "packet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest_file", "manifest_sha256"],
      "properties": {
        "manifest_file": {"type": "string", "minLength": 1},
        "manifest_sha256": {"$ref": "#/$defs/sha"}
      }
    },
    "report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "sha256"],
      "properties": {
        "file": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha"}
      }
    },
    "redTeamArtifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["receipts", "report_citations"],
      "properties": {
        "receipts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/file"}},
        "report_citations": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/file"}},
        "evidence_kinds": {
          "type": "array",
          "uniqueItems": true,
          "items": {"enum": ["independent-recompute", "counterexample", "small-enumeration", "alternative-formula", "search-challenge", "property-test", "action-activation-challenge", "geometry-continuous-validation"]}
        }
      }
    },
    "scientificIsolation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["thread_id", "fresh_context", "solver_context_visible", "previous_review_visible", "quality_verdicts_visible", "decision_log_visible_initially"],
      "properties": {
        "thread_id": {"type": "string", "minLength": 1},
        "fresh_context": {"const": true},
        "solver_context_visible": {"const": false},
        "previous_review_visible": {"const": false},
        "quality_verdicts_visible": {"const": false},
        "decision_log_visible_initially": {"const": false}
      }
    },
    "paperIsolation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["thread_id", "fresh_context", "solver_context_visible", "scientific_review_visible", "quality_verdicts_visible", "code_visible_initially"],
      "properties": {
        "thread_id": {"type": "string", "minLength": 1},
        "fresh_context": {"const": true},
        "solver_context_visible": {"const": false},
        "scientific_review_visible": {"const": false},
        "quality_verdicts_visible": {"const": false},
        "code_visible_initially": {"const": false}
      }
    },
    "reviewerReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["thread_id"],
      "properties": {
        "thread_id": {"type": "string", "minLength": 1}
      }
    },
    "scientificReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verdict", "highest_severity", "competition_strength", "full_rerun_required", "affected_questions", "packet", "report", "reviewer", "reviewed_at"],
      "properties": {
        "verdict": {"$ref": "#/$defs/verdict"},
        "highest_severity": {"$ref": "#/$defs/findingLevel"},
        "competition_strength": {"enum": ["weak", "qualified", "strong", "unknown"]},
        "full_rerun_required": {"type": "boolean"},
        "affected_questions": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "packet": {"$ref": "#/$defs/packet"},
        "report": {"$ref": "#/$defs/report"},
        "artifacts": {"$ref": "#/$defs/redTeamArtifacts"},
        "objective_semantics": {
          "oneOf": [{"type": "null"}, {"$ref": "#/$defs/report"}]
        },
        "question_reviews": {
          "oneOf": [{"type": "null"}, {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/questionReview"}}]
        },
        "reviewer": {"oneOf": [{"$ref": "#/$defs/scientificIsolation"}, {"$ref": "#/$defs/reviewerReference"}]},
        "reviewed_at": {"type": "string", "format": "date-time"}
      }
    },
    "paperBlindReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verdict", "highest_severity", "packet", "report", "reviewer", "reviewed_at"],
      "properties": {
        "verdict": {"$ref": "#/$defs/verdict"},
        "highest_severity": {"$ref": "#/$defs/findingLevel"},
        "packet": {"$ref": "#/$defs/packet"},
        "report": {"$ref": "#/$defs/report"},
        "assessment": {"$ref": "#/$defs/paperAssessment"},
        "reviewer": {"oneOf": [{"$ref": "#/$defs/paperIsolation"}, {"$ref": "#/$defs/reviewerReference"}]},
        "reviewed_at": {"type": "string", "format": "date-time"}
      }
    },
    "paperAssessment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["argumentation_complete", "readability_passed", "empty_sections", "unreadable_pages"],
      "properties": {
        "argumentation_complete": {"type": "boolean"},
        "readability_passed": {"type": "boolean"},
        "empty_sections": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "unreadable_pages": {"type": "array", "uniqueItems": true, "items": {"type": "integer", "minimum": 1}}
      }
    },
    "paperBlindReviewV14": {
      "allOf": [
        {"$ref": "#/$defs/paperBlindReview"},
        {
          "type": "object",
          "required": ["assessment"],
          "properties": {"assessment": {"$ref": "#/$defs/paperAssessment"}}
        }
      ]
    },
    "finalAudit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verdict", "highest_severity", "packet", "report", "reviewer", "reviewed_at"],
      "properties": {
        "verdict": {"$ref": "#/$defs/verdict"},
        "highest_severity": {"$ref": "#/$defs/findingLevel"},
        "packet": {"$ref": "#/$defs/packet"},
        "report": {"$ref": "#/$defs/report"},
        "reviewer": {"$ref": "#/$defs/reviewerReference"},
        "reviewed_at": {"type": "string", "format": "date-time"}
      }
    },
    "questionReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["question_id", "verdict", "competition_strength"],
      "properties": {
        "question_id": {"type": "string", "minLength": 1},
        "verdict": {"$ref": "#/$defs/verdict"},
        "competition_strength": {"enum": ["weak", "qualified", "strong", "unknown"]},
        "evidence_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"}
        },
        "blocking_findings": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
