{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/simple_visualization_plan.schema.json",
  "title": "Capability-First v3 Visualization Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "state_revision", "contracts", "created_at"],
  "properties": {
    "schema_version": {"enum": ["1.0", "1.1", "1.2", "1.3"]},
    "run_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
    "state_revision": {"type": "integer", "minimum": 0},
    "contracts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/contract"}},
    "created_at": {"type": "string", "format": "date-time"}
  },
  "allOf": [
    {
      "if": {"properties": {"schema_version": {"const": "1.0"}}},
      "then": {
        "properties": {
          "contracts": {
            "items": {"required": ["role", "purpose", "evidence_scope", "rationale", "source_paths", "rendering_mode", "outputs", "generator"]}
          }
        }
      }
    },
    {
      "if": {"properties": {"schema_version": {"const": "1.1"}}},
      "then": {
        "properties": {
          "contracts": {
            "items": {
              "required": ["scientific_question", "conclusion_impact", "selection_reason", "loss_if_omitted", "evidence_roles", "evidence_modes", "evidence_scope", "source_paths", "rendering_mode", "outputs", "generator"]
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"schema_version": {"const": "1.2"}}},
      "then": {
        "properties": {
          "contracts": {
            "items": {
              "required": ["scientific_question", "why_needed", "conclusion_impact", "evidence_roles", "evidence_modes", "evidence_scope"],
              "properties": {"status": {"enum": ["planned", "complete"]}},
              "not": {
                "anyOf": [
                  {"required": ["purpose"]},
                  {"required": ["selection_reason"]},
                  {"required": ["loss_if_omitted"]},
                  {"required": ["rationale"]},
                  {"required": ["waiver_reason"]},
                  {"required": ["replacement_for"]}
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"schema_version": {"const": "1.3"}}},
      "then": {
        "properties": {
          "contracts": {
            "items": {
              "required": ["scientific_question", "why_needed", "conclusion_impact", "evidence_roles", "evidence_modes", "evidence_scope"],
              "properties": {"status": {"enum": ["planned", "complete"]}},
              "allOf": [
                {
                  "if": {"properties": {"status": {"const": "complete"}}},
                  "then": {"required": ["render_receipt"]}
                }
              ],
              "not": {
                "anyOf": [
                  {"required": ["purpose"]},
                  {"required": ["selection_reason"]},
                  {"required": ["loss_if_omitted"]},
                  {"required": ["rationale"]},
                  {"required": ["waiver_reason"]},
                  {"required": ["replacement_for"]},
                  {"required": ["source_paths"]},
                  {"required": ["rendering_mode"]},
                  {"required": ["outputs"]},
                  {"required": ["generator"]},
                  {"required": ["generator_sha256"]},
                  {"required": ["source_receipts"]}
                ]
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["figure_id", "question_id", "status"],
      "properties": {
        "figure_id": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"},
        "role": {"enum": ["method_roadmap", "spatial_scene", "geometric_boundary", "optimization_convergence", "optimization_diagnostic", "optimization_certificate", "enumeration_coverage", "analytic_certificate", "spatiotemporal_coordination", "assignment_structure", "state_or_field", "network_topology_or_flow", "fit_residual_or_uncertainty", "sensitivity_or_rank_stability", "data_result"]},
        "question_id": {"type": "string", "minLength": 1},
        "purpose": {"type": "string", "minLength": 16},
        "scientific_question": {"type": "string", "minLength": 16},
        "why_needed": {"type": "string", "minLength": 16},
        "conclusion_impact": {"enum": ["primary", "supporting", "context"]},
        "selection_reason": {"type": "string", "minLength": 16},
        "loss_if_omitted": {"type": "string", "minLength": 16},
        "evidence_roles": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["model_structure", "solver_process", "optimality_evidence", "result_stability", "method_overview"]}},
        "evidence_modes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["spatial_3d", "orthographic_geometry", "planar_geometry", "heuristic_trace", "proxy_calibration", "local_landscape", "bound_gap", "residual_certificate", "enumeration_coverage", "analytic_derivation", "state_trajectory", "network_flow", "fit_diagnostics", "rank_stability", "result_comparison", "workflow_overview"]}},
        "evidence_scope": {"enum": ["model", "production_result", "search_diagnostic", "method_structure"]},
        "source_paths": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "result_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "rendering_mode": {"enum": ["2d", "3d", "orthographic", "diagram"]},
        "status": {"enum": ["planned", "complete", "waived"]},
        "waiver_reason": {"type": "string", "minLength": 16},
        "replacement_for": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Za-z0-9._-]+$"}},
        "outputs": {"type": "array", "items": {"anyOf": [{"$ref": "#/$defs/file"}, {"type": "string", "minLength": 1}]}},
        "source_receipts": {"type": "array", "items": {"$ref": "#/$defs/file"}},
        "generator": {"$ref": "#/$defs/generator"},
        "generator_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "render_receipt": {"oneOf": [{"type": "string", "minLength": 1}, {"$ref": "#/$defs/receiptReference"}]},
        "rationale": {"type": "string", "minLength": 16}
      }
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "script_path"],
      "properties": {
        "engine": {"enum": ["python", "matlab", "octave", "drawio", "graphviz", "other"]},
        "script_path": {"type": "string", "minLength": 1}
      }
    },
    "receiptReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    }
  }
}
