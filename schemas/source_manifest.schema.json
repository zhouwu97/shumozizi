{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/source_manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_name", "schema_version", "run_id", "bindings", "sources", "generated_at"],
  "properties": {
    "schema_name": {"const": "source_manifest"},
    "schema_version": {"const": "2.0"},
    "run_id": {"type": "string", "minLength": 1},
    "bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["final_pdf", "paper_plan", "result_registry"],
      "properties": {
        "final_pdf": {"$ref": "#/$defs/file"},
        "paper_plan": {"$ref": "#/$defs/file"},
        "result_registry": {"$ref": "#/$defs/file"}
      }
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["python", "matlab"],
      "properties": {
        "python": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/source"}
        },
        "matlab": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/source"}
        }
      }
    },
    "generated_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha"}
      }
    },
    "support": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "ref"],
      "properties": {
        "kind": {"enum": ["accepted_result", "figure", "paper_claim"]},
        "ref": {"type": "string", "minLength": 1}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "run_command", "dependencies", "question_ids", "supports"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha"},
        "run_command": {"type": "string", "minLength": 1},
        "dependencies": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "question_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "supports": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/support"}
        }
      }
    }
  }
}
