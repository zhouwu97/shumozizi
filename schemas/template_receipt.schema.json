{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhouwu97/shumozizi/schemas/template_receipt.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_name", "schema_version", "template_id", "template_version", "source_repository", "source_commit", "source_template_sha256", "local_adapter_sha256", "generator_id", "generator_version", "generator_sha256", "parameters_sha256", "generated_files"],
  "properties": {
    "schema_name": {"const": "template_receipt"},
    "schema_version": {"const": "2.0"},
    "template_id": {"type": "string"},
    "template_version": {"type": "string"},
    "source_repository": {"type": "string", "format": "uri"},
    "source_commit": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "source_template_sha256": {"$ref": "#/$defs/sha"},
    "local_adapter_sha256": {"$ref": "#/$defs/sha"},
    "generator_id": {"const": "instantiate-template"},
    "generator_version": {"type": "string"},
    "generator_sha256": {"$ref": "#/$defs/sha"},
    "parameters_sha256": {"$ref": "#/$defs/sha"},
    "generated_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {"path": {"type": "string"}, "sha256": {"$ref": "#/$defs/sha"}}
      }
    }
  },
  "$defs": {"sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
